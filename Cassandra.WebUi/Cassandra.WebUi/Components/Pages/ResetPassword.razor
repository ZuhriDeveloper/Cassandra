@page "/reset-password"
@layout LoginLayout
@rendermode InteractiveServer
@using Cassandra.WebUi.Services
@inject AuthService Auth

<PageTitle>Atur Ulang Kata Sandi — ModeOn</PageTitle>

<AuthCard Title="Atur Ulang Kata Sandi"
          Subtitle="Buat kata sandi baru untuk akun Anda.">
    @if (_invalidLink)
    {
        <div class="alert alert-danger py-2 small" role="alert">
            Tautan tidak valid atau sudah kedaluwarsa. Silakan minta tautan baru.
        </div>
        <a href="/forgot-password" class="btn btn-outline-secondary w-100">
            <i class="bi bi-arrow-repeat me-1"></i> Minta Tautan Baru
        </a>
    }
    else if (_done)
    {
        <div class="alert alert-success py-2 small d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-check-circle flex-shrink-0"></i>
            <span>@_message</span>
        </div>
        <a href="/login" class="btn btn-primary w-100">
            <i class="bi bi-box-arrow-in-right me-1"></i> Masuk
        </a>
    }
    else
    {
        @if (_errors.Count > 0)
        {
            <div class="alert alert-danger py-2 small" role="alert">
                <ul class="mb-0 ps-3">
                    @foreach (var e in _errors) { <li>@e</li> }
                </ul>
            </div>
        }

        <EditForm Model="this" OnValidSubmit="HandleSubmit">
            <div class="mb-3">
                <label class="form-label" for="newPassword">Kata Sandi Baru</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <InputText id="newPassword" @bind-Value="_newPassword" type="password"
                               class="form-control" autocomplete="new-password"
                               placeholder="Min. 8 karakter, 1 angka, 1 huruf kapital" />
                </div>
                <div class="form-text">Min. 8 karakter, setidaknya 1 angka dan 1 huruf kapital.</div>
            </div>
            <div class="mb-4">
                <label class="form-label" for="confirmPassword">Ulangi Kata Sandi Baru</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                    <InputText id="confirmPassword" @bind-Value="_confirmPassword" type="password"
                               class="form-control" autocomplete="new-password" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100" disabled="@_busy">
                @if (_busy)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                else
                {
                    <i class="bi bi-check-lg me-1"></i>
                }
                Simpan Kata Sandi
            </button>
        </EditForm>
    }
</AuthCard>

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _busy;
    private bool _done;
    private bool _invalidLink;
    private string? _message;
    private readonly List<string> _errors = [];

    protected override void OnInitialized()
        => _invalidLink = string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token);

    private async Task HandleSubmit()
    {
        _errors.Clear();

        foreach (var e in ValidatePassword(_newPassword))
            _errors.Add(e);
        if (_newPassword != _confirmPassword)
            _errors.Add("Konfirmasi kata sandi tidak cocok.");
        if (_errors.Count > 0)
            return;

        _busy = true;
        var result = await Auth.ResetPasswordAsync(Email!.Trim(), Token!, _newPassword);
        _busy = false;

        if (result.Ok)
        {
            _message = result.Message ?? "Kata sandi berhasil diatur ulang. Silakan masuk.";
            _done = true;
        }
        else
        {
            _errors.AddRange(result.Errors);
        }
    }

    private static List<string> ValidatePassword(string? pwd)
    {
        var errs = new List<string>();
        if (string.IsNullOrEmpty(pwd) || pwd.Length < 8)
            errs.Add("Kata sandi minimal 8 karakter.");
        if (pwd is not null && !pwd.Any(char.IsDigit))
            errs.Add("Kata sandi harus mengandung setidaknya 1 angka.");
        if (pwd is not null && !pwd.Any(char.IsUpper))
            errs.Add("Kata sandi harus mengandung setidaknya 1 huruf kapital.");
        return errs;
    }
}
