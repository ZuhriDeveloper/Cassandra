@page "/dealer/pelanggaran-wilayah"
@attribute [Authorize(Roles = "Admin,Sales,Cashier")]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Cassandra.WebUi.Services
@inject MasterDataApiClient Api

<PageTitle>Pelanggaran Wilayah — Cassandra</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">Pelanggaran Wilayah</h4>
</div>

@if (_errors.Count > 0)
{
    <div class="alert alert-danger alert-dismissible">
        <ul class="mb-0 ps-3">
            @foreach (var e in _errors)
            {
                <li>@e</li>
            }
        </ul>
        <button type="button" class="btn-close" @onclick="() => _errors.Clear()"></button>
    </div>
}
@if (!string.IsNullOrEmpty(_notice))
{
    <div class="alert alert-success alert-dismissible">
        @_notice
        <button type="button" class="btn-close" @onclick="() => _notice = null"></button>
    </div>
}

<div class="row g-4">

    @* ── Left: Create / Edit form ── *@
    <div class="col-lg-4">
        @if (_editingId is null)
        {
            <div class="card">
                <div class="card-header fw-semibold">
                    <i class="bi bi-plus-circle me-1"></i> Tambah Pelanggaran Wilayah Baru
                </div>
                <div class="card-body">
                    <EditForm Model="_createForm" OnValidSubmit="HandleCreate">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label">Kode Area <span class="text-danger">*</span></label>
                            <InputText class="form-control text-uppercase" @bind-Value="_createForm.AreaCode"
                                       @oninput="e => _createForm.AreaCode = e.Value?.ToString()?.ToUpperInvariant() ?? string.Empty"
                                       placeholder="cth. DKI-LUAR" />
                            <ValidationMessage For="() => _createForm.AreaCode" class="small text-danger" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Biaya Tambahan (Rp) <span class="text-danger">*</span></label>
                            <InputNumber class="form-control" @bind-Value="_createForm.ExtraFee" />
                            <ValidationMessage For="() => _createForm.ExtraFee" class="small text-danger" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100" disabled="@_saving">
                            @if (_saving)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            else
                            {
                                <i class="bi bi-check-lg me-1"></i>
                            }
                            Simpan Pelanggaran Wilayah
                        </button>
                    </EditForm>
                </div>
            </div>
        }
        else
        {
            <div class="card border-warning">
                <div class="card-header fw-semibold text-warning-emphasis bg-warning-subtle d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-pencil me-1"></i> Ubah Pelanggaran Wilayah</span>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CancelEdit">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="card-body">
                    <EditForm Model="_editForm" OnValidSubmit="HandleUpdate">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label">Kode Area</label>
                            <p class="form-control-plaintext fw-semibold">@_editForm.AreaCode</p>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Biaya Tambahan (Rp) <span class="text-danger">*</span></label>
                            <InputNumber class="form-control" @bind-Value="_editForm.ExtraFee" />
                            <ValidationMessage For="() => _editForm.ExtraFee" class="small text-danger" />
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning flex-grow-1" disabled="@_saving">
                                @if (_saving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <i class="bi bi-check-lg me-1"></i>
                                }
                                Simpan
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit">Batal</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }
    </div>

    @* ── Right: list ── *@
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header fw-semibold">Semua Pelanggaran Wilayah</div>
            <div class="card-body p-0">
                @if (_list is null)
                {
                    <div class="p-3 text-muted">
                        <span class="spinner-border spinner-border-sm me-1"></span> Memuat…
                    </div>
                }
                else if (_list.Count == 0)
                {
                    <div class="p-3 text-muted">Belum ada pelanggaran wilayah yang terdaftar.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Kode Area</th>
                                    <th class="text-end">Biaya Tambahan</th>
                                    <th>Status</th>
                                    <th class="text-end">Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _list)
                                {
                                    <tr class="@(_editingId == item.Id ? "table-warning" : "")">
                                        <td class="fw-semibold">@item.AreaCode</td>
                                        <td class="text-end">Rp @item.ExtraFee.ToString("N2")</td>
                                        <td>
                                            @if (item.IsActive)
                                            {
                                                <span class="badge bg-success">Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Tidak Aktif</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <AuthorizeView Roles="Admin">
                                                <div class="d-flex gap-1 justify-content-end">
                                                    <button class="btn btn-sm @(_editingId == item.Id ? "btn-warning" : "btn-outline-secondary")"
                                                            title="Ubah" @onclick="() => StartEdit(item)">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    @if (item.IsActive)
                                                    {
                                                        <button class="btn btn-sm btn-outline-danger"
                                                                title="Nonaktifkan"
                                                                @onclick="() => HandleToggleStatus(item)">
                                                            <i class="bi bi-toggle-on"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-outline-success"
                                                                title="Aktifkan"
                                                                @onclick="() => HandleToggleStatus(item)">
                                                            <i class="bi bi-toggle-off"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </AuthorizeView>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

@code {
    private List<PelanggaranWilayahDto>? _list;
    private Guid?                         _editingId;
    private string?                       _notice;
    private bool                          _saving;

    private readonly List<string> _errors = [];

    private PelanggaranWilayahCreateForm _createForm = new();
    private PelanggaranWilayahEditForm   _editForm   = new();

    protected override async Task OnInitializedAsync()
        => _list = await Api.GetPelanggaranWilayahAsync() ?? [];

    private async Task LoadAsync()
        => _list = await Api.GetPelanggaranWilayahAsync() ?? [];

    private async Task HandleCreate()
    {
        _errors.Clear();
        _saving = true;

        var (id, errors) = await Api.CreatePelanggaranWilayahAsync(
            _createForm.AreaCode.Trim(),
            _createForm.ExtraFee);

        _saving = false;

        if (errors is not null) { _errors.AddRange(errors); return; }

        _notice     = $"Pelanggaran Wilayah '{_createForm.AreaCode}' berhasil ditambahkan.";
        _createForm = new();
        await LoadAsync();
    }

    private async Task HandleUpdate()
    {
        if (_editingId is null) return;

        _errors.Clear();
        _saving = true;

        var errors = await Api.UpdatePelanggaranWilayahAsync(
            _editingId.Value,
            _editForm.ExtraFee);

        _saving = false;

        if (errors is not null) { _errors.AddRange(errors); return; }

        _notice    = "Pelanggaran Wilayah berhasil diperbarui.";
        _editingId = null;
        _editForm  = new();
        await LoadAsync();
    }

    private async Task HandleToggleStatus(PelanggaranWilayahDto item)
    {
        _errors.Clear();

        var errors = await Api.SetPelanggaranWilayahStatusAsync(item.Id, !item.IsActive);

        if (errors is not null) { _errors.AddRange(errors); return; }

        _notice = $"Pelanggaran Wilayah '{item.AreaCode}' berhasil {(item.IsActive ? "dinonaktifkan" : "diaktifkan")}.";
        await LoadAsync();
    }

    private void StartEdit(PelanggaranWilayahDto item)
    {
        _editingId        = item.Id;
        _editForm.AreaCode = item.AreaCode;
        _editForm.ExtraFee = item.ExtraFee;
        _errors.Clear();
        _notice = null;
    }

    private void CancelEdit()
    {
        _editingId = null;
        _editForm  = new();
        _errors.Clear();
    }

    // ── Form models ────────────────────────────────────────────────────────────

    private sealed class PelanggaranWilayahCreateForm
    {
        [Required(ErrorMessage = "Kode area wajib diisi.")]
        [MaxLength(50, ErrorMessage = "Kode area maksimal 50 karakter.")]
        public string AreaCode { get; set; } = string.Empty;

        [Range(0, double.MaxValue, ErrorMessage = "Biaya tambahan tidak boleh negatif.")]
        public decimal ExtraFee { get; set; }
    }

    private sealed class PelanggaranWilayahEditForm
    {
        public string AreaCode { get; set; } = string.Empty;

        [Range(0, double.MaxValue, ErrorMessage = "Biaya tambahan tidak boleh negatif.")]
        public decimal ExtraFee { get; set; }
    }
}
