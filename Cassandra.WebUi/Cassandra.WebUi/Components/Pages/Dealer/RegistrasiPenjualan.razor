@page "/dealer/registrasi-penjualan"
@attribute [Authorize(Roles = "Admin,Sales,Cashier")]
@rendermode InteractiveServer
@using System.Globalization
@using Cassandra.WebUi.Services
@inject MasterDataApiClient Api

<PageTitle>Registrasi Penjualan — Cassandra</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">Registrasi Penjualan</MudText>
    <AuthorizeView Roles="Admin,Sales">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" DropShadow="false"
                   StartIcon="@(_showCreate ? Icons.Material.Filled.Close : Icons.Material.Filled.Add)"
                   OnClick="ToggleCreate">
            @(_showCreate ? "Tutup Form" : "Tambah Penjualan")
        </MudButton>
    </AuthorizeView>
</MudStack>

@if (_errors.Count > 0)
{
    <MudAlert Severity="Severity.Error" Class="mb-4"
              ShowCloseIcon="true" CloseIconClicked="@(() => _errors.Clear())">
        <ul class="my-0 pl-4">
            @foreach (var e in _errors)
            {
                <li>@e</li>
            }
        </ul>
    </MudAlert>
}
@if (!string.IsNullOrEmpty(_notice))
{
    <MudAlert Severity="Severity.Success" Class="mb-4"
              ShowCloseIcon="true" CloseIconClicked="@(() => _notice = null)">
        @_notice
    </MudAlert>
}

@* ── Create form ── *@
@if (_showCreate)
{
    <MudCard Outlined="true" Elevation="0" Class="mb-4" Style="max-width:1100px">

        <MudCardHeader Class="pb-2">
            <CardHeaderAvatar>
                <MudAvatar Color="Color.Primary" Variant="Variant.Outlined" Rounded="true">
                    <MudIcon Icon="@Icons.Material.Outlined.TwoWheeler" />
                </MudAvatar>
            </CardHeaderAvatar>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Tambah Registrasi Penjualan Baru</MudText>
                <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary)">
                    Catat penjualan unit baru — kolom bertanda * wajib diisi.
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent Class="pt-2">

            @* ── Data kendaraan & penjualan ── *@
            <MudText Typo="Typo.overline" Style="color:var(--mud-palette-text-secondary)">
                Data Kendaraan &amp; Penjualan
            </MudText>
            <MudGrid Spacing="3" Class="mt-0">
                <MudItem xs="12" sm="6" md="4">
                    <MudTextField T="string" @bind-Value="_noPenjualan"
                                  Label="No. Penjualan" Placeholder="cth. PJ-2025-001" Required="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudDatePicker @bind-Date="SaleDateProxy"
                                   Label="Tanggal Penjualan" DateFormat="dd/MM/yyyy" Editable="true"
                                   AdornmentIcon="@Icons.Material.Outlined.CalendarMonth"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudSelect T="Guid" @bind-Value="_karyawanId"
                               Label="Sales / Karyawan" Placeholder="— Pilih Karyawan —"
                               Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" Dense="true">
                        @foreach (var k in (_karyawans ?? []).Where(k => k.IsActive))
                        {
                            <MudSelectItem T="Guid" Value="@k.Id">@k.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudSelect T="Guid" @bind-Value="_kiosId"
                               Label="Kios" Placeholder="— Pilih Kios —"
                               Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" Dense="true">
                        @foreach (var k in (_kiosList ?? []).Where(k => k.IsActive))
                        {
                            <MudSelectItem T="Guid" Value="@k.Id">@k.Code — @k.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudSelect T="Guid?" @bind-Value="_mediatorId"
                               Label="Mediator" Placeholder="— Tanpa Mediator —"
                               Clearable="true" HelperText="Opsional"
                               Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" Dense="true">
                        @foreach (var m in (_mediators ?? []).Where(m => m.IsActive))
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)m.Id)">@m.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudSelect T="string" @bind-Value="_tipePenjualan"
                               Label="Tipe Penjualan"
                               Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" Dense="true">
                        <MudSelectItem T="string" Value="@("DIRECT")">DIRECT</MudSelectItem>
                        <MudSelectItem T="string" Value="@("KIOS")">KIOS</MudSelectItem>
                        <MudSelectItem T="string" Value="@("MEDIATOR")">MEDIATOR</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudTextField T="string" @bind-Value="_noMesin"
                                  Label="No. Mesin" Placeholder="Nomor mesin unit" Required="true"
                                  Immediate="true" OnBlur="OnNoMesinBlur" Class="mono"
                                  HelperText="Tab keluar untuk auto-isi No. Rangka dari stok."
                                  Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudTextField T="string" @bind-Value="_noRangka"
                                  Label="No. Rangka" Placeholder="Nomor rangka unit" Required="true" Class="mono"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudTextField T="string" @bind-Value="_serahTerimaKendaraanId"
                                  Label="No. Serah Terima Kendaraan" Placeholder="No. STK" Required="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudTextField T="string" @bind-Value="_tandaTerimaSementaraId"
                                  Label="No. Tanda Terima Sementara" Placeholder="No. TTS" HelperText="Opsional"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-5" />

            @* ── Data finansial ── *@
            <MudText Typo="Typo.overline" Style="color:var(--mud-palette-text-secondary)">
                Data Finansial
            </MudText>

            <MudText Typo="Typo.caption" Class="mt-2 mb-1 d-block"
                     Style="color:var(--mud-palette-text-secondary);font-weight:600">
                Metode Penjualan *
            </MudText>
            <MudToggleGroup T="string" Value="@_metodePenjualan" ValueChanged="OnMetodeChanged"
                            SelectionMode="SelectionMode.SingleSelection"
                            Color="Color.Primary" CheckMark="false" Delimiters="false" Ripple="false"
                            Class="segmented d-inline-flex" SelectedClass="segmented-selected" Size="Size.Small">
                <MudToggleItem T="string" Value="@("CASH")">
                    <MudIcon Icon="@Icons.Material.Outlined.Payments" Size="Size.Small" Class="mr-2" />CASH
                </MudToggleItem>
                <MudToggleItem T="string" Value="@("CREDIT")">
                    <MudIcon Icon="@Icons.Material.Outlined.CreditCard" Size="Size.Small" Class="mr-2" />CREDIT
                </MudToggleItem>
            </MudToggleGroup>

            <MudGrid Spacing="3" Class="mt-1">
                <MudItem xs="12" sm="6" md="4">
                    <MudNumericField T="decimal" @bind-Value="_total"
                                     Label="Harga Total" Required="true"
                                     Adornment="Adornment.Start" AdornmentText="Rp"
                                     Format="N0" Culture="@IdCulture" HideSpinButtons="true" Min="0"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudNumericField T="decimal" @bind-Value="_offRoad"
                                     Label="Off Road"
                                     Adornment="Adornment.Start" AdornmentText="Rp"
                                     Format="N0" Culture="@IdCulture" HideSpinButtons="true" Min="0"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudNumericField T="decimal" @bind-Value="_bbn"
                                     Label="BBN"
                                     Adornment="Adornment.Start" AdornmentText="Rp"
                                     Format="N0" Culture="@IdCulture" HideSpinButtons="true" Min="0"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudNumericField T="decimal" @bind-Value="_discount"
                                     Label="Diskon yang Diminta"
                                     Adornment="Adornment.Start" AdornmentText="Rp"
                                     Format="N0" Culture="@IdCulture" HideSpinButtons="true" Min="0"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudNumericField T="decimal" @bind-Value="_ambilUang"
                                     Label="Ambil Uang"
                                     Adornment="Adornment.Start" AdornmentText="Rp"
                                     Format="N0" Culture="@IdCulture" HideSpinButtons="true" Min="0"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>

                @if (_metodePenjualan == "CREDIT")
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudNumericField T="decimal" @bind-Value="_dp"
                                         Label="DP (Uang Muka)"
                                         Adornment="Adornment.Start" AdornmentText="Rp"
                                         Format="N0" Culture="@IdCulture" HideSpinButtons="true" Min="0"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudNumericField T="decimal" @bind-Value="_angsuran"
                                         Label="Angsuran / Bulan"
                                         Adornment="Adornment.Start" AdornmentText="Rp"
                                         Format="N0" Culture="@IdCulture" HideSpinButtons="true" Min="0"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudSelect T="Guid?" @bind-Value="_daftarHargaLeasingId"
                                   Label="Daftar Harga Leasing" Placeholder="— Pilih Daftar Harga Leasing —"
                                   Clearable="true"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" Dense="true">
                            @foreach (var d in (_daftarHargaLeasings ?? []).Where(d => d.IsActive))
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)d.Id)">@d.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudTextField T="string" @bind-Value="_tenorCode"
                                      Label="Tenor Code" Placeholder="cth. T24" HelperText="Opsional"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                    </MudItem>
                }
            </MudGrid>

            <MudDivider Class="my-5" />

            @* ── Data konsumen ── *@
            <MudText Typo="Typo.overline" Style="color:var(--mud-palette-text-secondary)">
                Data Konsumen
            </MudText>
            <MudGrid Spacing="3" Class="mt-0">
                <MudItem xs="12" sm="6" md="4">
                    <MudTextField T="string" @bind-Value="_namaCustomer"
                                  Label="Nama Konsumen" Placeholder="Nama lengkap" Required="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudTextField T="string" @bind-Value="_phone"
                                  Label="Telepon" Placeholder="No. telepon utama" Required="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudTextField T="string" @bind-Value="_phone1"
                                  Label="Telepon 1" Placeholder="No. telepon alternatif" HelperText="Opsional"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudTextField T="string" @bind-Value="_phone2"
                                  Label="Telepon 2" Placeholder="No. telepon alternatif 2" HelperText="Opsional"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" md="8">
                    <MudTextField T="string" @bind-Value="_address"
                                  Label="Alamat" Placeholder="Alamat lengkap" Required="true" Lines="2"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-5" />

            @* ── Kelengkapan ── *@
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                <MudStack Row="true" AlignItems="AlignItems.Baseline" Spacing="1">
                    <MudText Typo="Typo.overline" Style="color:var(--mud-palette-text-secondary)">Kelengkapan</MudText>
                    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">(opsional)</MudText>
                </MudStack>
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="AddKelengkapan">
                    Tambah
                </MudButton>
            </MudStack>
            @if (_kelengkapan.Count > 0)
            {
                <MudGrid Spacing="2">
                    @foreach (var (item, idx) in _kelengkapan.Select((v, i) => (v, i)))
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudAutocomplete T="string"
                                                 Value="@item"
                                                 ValueChanged="@(v => _kelengkapan[idx] = v ?? string.Empty)"
                                                 SearchFunc="SearchKelengkapan"
                                                 CoerceValue="true" Clearable="true"
                                                 Placeholder="Nama kelengkapan"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => RemoveKelengkapan(idx))" />
                            </MudStack>
                        </MudItem>
                    }
                </MudGrid>
            }

        </MudCardContent>

        <MudCardActions Class="px-4 pb-4 pt-0">
            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="flex-grow-1">
                <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="ToggleCreate">
                    Batal
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" DropShadow="false"
                           StartIcon="@(_saving ? null : Icons.Material.Filled.Check)"
                           OnClick="HandleCreate" Disabled="_saving">
                    @if (_saving)
                    {
                        <MudProgressCircular Indeterminate="true" Color="Color.Inherit"
                                             Style="width:18px;height:18px" Class="mr-2" />
                    }
                    @(_saving ? "Menyimpan…" : "Simpan Penjualan")
                </MudButton>
            </MudStack>
        </MudCardActions>

    </MudCard>
}

@* ── Approve inline form ── *@
@if (_approvingId.HasValue)
{
    <MudCard Outlined="true" Elevation="0" Class="mb-4"
             Style="max-width:1100px;border-left:3px solid var(--mud-palette-warning)">
        <MudCardHeader Class="pb-0">
            <CardHeaderContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Color="Color.Warning" />
                    <MudText Typo="Typo.h6">Approve Penjualan</MudText>
                </MudStack>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="@(() => _approvingId = null)" />
            </CardHeaderActions>
        </MudCardHeader>
        <MudCardContent>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="5" md="4">
                    <MudNumericField T="decimal" @bind-Value="_approvedDiscount"
                                     Label="Diskon yang Disetujui" Required="true"
                                     Adornment="Adornment.Start" AdornmentText="Rp"
                                     Format="N0" Culture="@IdCulture" HideSpinButtons="true" Min="0"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="7" md="8">
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" DropShadow="false"
                                   OnClick="HandleApprove" Disabled="_saving">
                            @(_saving ? "Menyimpan…" : "Simpan Approve")
                        </MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Default"
                                   OnClick="@(() => _approvingId = null)">
                            Batal
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>
}

@* ── Detail view ── *@
@if (_viewingDetail is not null)
{
    <MudCard Outlined="true" Elevation="0" Class="mb-4"
             Style="border-left:3px solid var(--mud-palette-info)">
        <MudCardHeader Class="pb-0">
            <CardHeaderContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Visibility" Color="Color.Info" />
                    <MudText Typo="Typo.h6">Detail — @_viewingDetail.NoPenjualan</MudText>
                </MudStack>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="@(() => _viewingDetail = null)" />
            </CardHeaderActions>
        </MudCardHeader>
        <MudCardContent>
            <MudGrid Spacing="3">
                @DetailItem("No. Penjualan", _viewingDetail.NoPenjualan, strong: true)
                @DetailItem("Tanggal", _viewingDetail.SaleDate.ToString("dd/MM/yyyy"))
                @DetailItem("Metode", _viewingDetail.MetodePenjualan)
                @DetailItem("Tipe", _viewingDetail.TipePenjualan)
                @DetailItem("No. Mesin", _viewingDetail.NoMesin, mono: true)
                @DetailItem("No. Rangka", _viewingDetail.NoRangka, mono: true)
                @DetailItem("Nama Konsumen", _viewingDetail.NamaCustomer, strong: true)
                @DetailItem("Alamat", _viewingDetail.Address, wide: true)
                @DetailItem("Telepon", _viewingDetail.Phone)
                @DetailItem("Tipe Motor", _viewingDetail.TipeMotorCode)
                @DetailItem("Warna", _viewingDetail.WarnaName)
                @DetailItem("Total", _viewingDetail.Total.ToString("N0"), strong: true)
                @DetailItem("Off Road", _viewingDetail.OffRoad.ToString("N0"))
                @DetailItem("BBN", _viewingDetail.Bbn.ToString("N0"))
                @DetailItem("Diskon", _viewingDetail.Discount.ToString("N0"))
                @DetailItem("Diskon Disetujui", _viewingDetail.ApprovedDiscount.ToString("N0"))
                @DetailItem("TAC", _viewingDetail.Tac.ToString("N0"))
                @if (_viewingDetail.MetodePenjualan == "CREDIT")
                {
                    @DetailItem("DP", _viewingDetail.Dp.ToString("N0"))
                    @DetailItem("Angsuran", _viewingDetail.Angsuran.ToString("N0"))
                    @DetailItem("Tenor", _viewingDetail.TenorCode)
                }
                @if (_viewingDetail.Kelengkapan is { Count: > 0 })
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)"
                                 Class="mb-1 d-block">Kelengkapan</MudText>
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var k in _viewingDetail.Kelengkapan)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">@k</MudChip>
                            }
                        </div>
                    </MudItem>
                }
                @DetailItem("No. STK", _viewingDetail.SerahTerimaKendaraanId)
                @if (_viewingDetail.TandaTerimaSementaraId is not null)
                {
                    @DetailItem("No. TTS", _viewingDetail.TandaTerimaSementaraId)
                }
            </MudGrid>
        </MudCardContent>
    </MudCard>
}

@* ── List table ── *@
<MudTable T="RegistrasiPenjualanDto" Items="@(_list ?? [])"
          Hover="true" Dense="true" Outlined="true" Elevation="0"
          Breakpoint="Breakpoint.Sm"
          Loading="@(_list is null)" LoadingProgressColor="Color.Primary"
          RowClassFunc="@((reg, _) => _viewingDetail?.Id == reg.Id ? "row-active" : string.Empty)">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Semua Registrasi Penjualan</MudText>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>No. Penjualan</MudTh>
        <MudTh>Tgl</MudTh>
        <MudTh>Sales</MudTh>
        <MudTh>Kios</MudTh>
        <MudTh>Metode</MudTh>
        <MudTh>No. Mesin</MudTh>
        <MudTh>Nama Konsumen</MudTh>
        <MudTh Style="text-align:right">Total</MudTh>
        <MudTh>Status</MudTh>
        <MudTh Style="text-align:right">Aksi</MudTh>
    </HeaderContent>
    <RowTemplate Context="reg">
        <MudTd DataLabel="No. Penjualan" Style="font-weight:600">@reg.NoPenjualan</MudTd>
        <MudTd DataLabel="Tgl">@reg.SaleDate.ToString("dd/MM/yyyy")</MudTd>
        <MudTd DataLabel="Sales">@KaryawanName(reg.KaryawanId)</MudTd>
        <MudTd DataLabel="Kios">@KiosCode(reg.KiosId)</MudTd>
        <MudTd DataLabel="Metode">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                     Color="@(reg.MetodePenjualan == "CREDIT" ? Color.Info : Color.Primary)">
                @reg.MetodePenjualan
            </MudChip>
        </MudTd>
        <MudTd DataLabel="No. Mesin" Class="mono">@reg.NoMesin</MudTd>
        <MudTd DataLabel="Nama Konsumen">@reg.NamaCustomer</MudTd>
        <MudTd DataLabel="Total" Style="text-align:right">@reg.Total.ToString("N0")</MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@StatusColor(reg.Status)">
                @reg.Status
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Aksi" Style="text-align:right">
            <MudStack Row="true" Spacing="0" Justify="Justify.FlexEnd">
                <MudTooltip Text="Detail">
                    <MudIconButton Icon="@Icons.Material.Outlined.Visibility" Size="Size.Small"
                                   Color="Color.Info" OnClick="@(() => ViewDetail(reg))" />
                </MudTooltip>
                <AuthorizeView Roles="Admin" Context="auth">
                    @if (reg.Status == "PENDING")
                    {
                        <MudTooltip Text="Approve">
                            <MudIconButton Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Small"
                                           Color="Color.Success" OnClick="@(() => StartApprove(reg))" />
                        </MudTooltip>
                    }
                    @if (reg.EnableToVoid)
                    {
                        <MudTooltip Text="Larang Void">
                            <MudIconButton Icon="@Icons.Material.Outlined.GppBad" Size="Size.Small"
                                           Color="Color.Default" OnClick="@(() => HandleSetEnableToVoid(reg, false))" />
                        </MudTooltip>
                    }
                    else
                    {
                        <MudTooltip Text="Izinkan Void">
                            <MudIconButton Icon="@Icons.Material.Outlined.GppGood" Size="Size.Small"
                                           Color="Color.Default" OnClick="@(() => HandleSetEnableToVoid(reg, true))" />
                        </MudTooltip>
                    }
                    @if (reg.Status != "VOID" && reg.EnableToVoid)
                    {
                        <MudTooltip Text="Void">
                            <MudIconButton Icon="@Icons.Material.Outlined.Block" Size="Size.Small"
                                           Color="Color.Error" OnClick="@(() => HandleVoid(reg))" />
                        </MudTooltip>
                    }
                </AuthorizeView>
            </MudStack>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary)">
            @(_list is null ? "Memuat…" : "Belum ada registrasi penjualan yang terdaftar.")
        </MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private static readonly CultureInfo IdCulture = CultureInfo.GetCultureInfo("id-ID");

    private List<RegistrasiPenjualanDto>? _list;
    private List<KaryawanDto>?            _karyawans;
    private List<KiosDto>?                _kiosList;
    private List<MediatorDto>?            _mediators;
    private List<KelengkapanDto>?         _kelengkapans;
    private List<DaftarHargaLeasingDto>?  _daftarHargaLeasings;
    private bool                          _showCreate;
    private bool                          _saving;
    private readonly List<string>         _errors = [];
    private string?                       _notice;
    private RegistrasiPenjualanDto?       _viewingDetail;

    // Form fields
    private string     _noPenjualan            = "";
    private DateOnly   _saleDate               = DateOnly.FromDateTime(DateTime.Today);
    private Guid       _karyawanId;
    private Guid       _kiosId;
    private Guid?      _mediatorId;
    private string     _metodePenjualan        = "CASH";
    private string     _tipePenjualan          = "DIRECT";
    private string     _noMesin                = "";
    private string     _noRangka               = "";
    private string     _namaCustomer           = "";
    private string     _address                = "";
    private string     _phone                  = "";
    private string?    _phone1;
    private string?    _phone2;
    private decimal    _offRoad;
    private decimal    _bbn;
    private decimal    _discount;
    private decimal    _total;
    private decimal    _ambilUang;
    private decimal    _dp;
    private decimal    _angsuran;
    private Guid?      _daftarHargaLeasingId;
    private string?    _tenorCode;
    private string     _serahTerimaKendaraanId = "";
    private string?    _tandaTerimaSementaraId;
    private List<string> _kelengkapan          = [];

    // Approve inline state
    private Guid?   _approvingId;
    private decimal _approvedDiscount;

    // MudDatePicker binds DateTime? — bridge to the DateOnly field.
    private DateTime? SaleDateProxy
    {
        get => _saleDate.ToDateTime(TimeOnly.MinValue);
        set { if (value.HasValue) _saleDate = DateOnly.FromDateTime(value.Value); }
    }

    // ── Lifecycle ──────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        var listTask    = Api.GetRegistrasiPenjualansAsync();
        var karyTask    = Api.GetKaryawanAsync();
        var kiosTask    = Api.GetKiosAsync();
        var medTask     = Api.GetMediatorsAsync();
        var klTask      = Api.GetKelengkapanAsync();
        var dhlTask     = Api.GetDaftarHargaLeasingAsync();
        await Task.WhenAll(listTask, karyTask, kiosTask, medTask, klTask, dhlTask);
        _list                = listTask.Result  ?? [];
        _karyawans           = karyTask.Result  ?? [];
        _kiosList            = kiosTask.Result  ?? [];
        _mediators           = medTask.Result   ?? [];
        _kelengkapans        = klTask.Result    ?? [];
        _daftarHargaLeasings = dhlTask.Result   ?? [];
    }

    private async Task LoadAsync()
        => _list = await Api.GetRegistrasiPenjualansAsync() ?? [];

    // ── Actions ────────────────────────────────────────────────────────────────

    private void ToggleCreate()
    {
        _showCreate = !_showCreate;
        if (!_showCreate) ResetForm();
    }

    private void OnMetodeChanged(string? metode)
    {
        // Re-clicking the selected pill deselects it in MudToggleGroup — ignore that.
        if (string.IsNullOrEmpty(metode)) return;

        _metodePenjualan = metode;
        if (metode == "CASH")
        {
            _dp                   = 0;
            _angsuran             = 0;
            _daftarHargaLeasingId = null;
            _tenorCode            = null;
        }
    }

    private async Task OnNoMesinBlur()
    {
        if (string.IsNullOrWhiteSpace(_noMesin) || _kiosId == Guid.Empty)
            return;

        var stocks = await Api.GetStocksByKiosAsync(_kiosId);
        var match  = stocks?.FirstOrDefault(s =>
            s.NoMesin.Equals(_noMesin.Trim(), StringComparison.OrdinalIgnoreCase));
        if (match is not null)
        {
            _noRangka = match.NoRangka;
        }
    }

    private void AddKelengkapan()    => _kelengkapan.Add("");
    private void RemoveKelengkapan(int idx) => _kelengkapan.RemoveAt(idx);

    private Task<IEnumerable<string>> SearchKelengkapan(string value, CancellationToken _)
    {
        var options = (_kelengkapans ?? []).Where(k => k.IsActive).Select(k => k.Name);
        if (!string.IsNullOrWhiteSpace(value))
            options = options.Where(o => o.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(options);
    }

    private async Task HandleCreate()
    {
        _errors.Clear();

        if (string.IsNullOrWhiteSpace(_noPenjualan))          { _errors.Add("No. Penjualan wajib diisi."); return; }
        if (_karyawanId == Guid.Empty)                         { _errors.Add("Karyawan wajib dipilih."); return; }
        if (_kiosId == Guid.Empty)                             { _errors.Add("Kios wajib dipilih."); return; }
        if (string.IsNullOrWhiteSpace(_noMesin))              { _errors.Add("No. Mesin wajib diisi."); return; }
        if (string.IsNullOrWhiteSpace(_noRangka))             { _errors.Add("No. Rangka wajib diisi."); return; }
        if (string.IsNullOrWhiteSpace(_namaCustomer))         { _errors.Add("Nama Konsumen wajib diisi."); return; }
        if (string.IsNullOrWhiteSpace(_address))              { _errors.Add("Alamat wajib diisi."); return; }
        if (string.IsNullOrWhiteSpace(_phone))                { _errors.Add("Telepon wajib diisi."); return; }
        if (string.IsNullOrWhiteSpace(_serahTerimaKendaraanId)) { _errors.Add("No. Serah Terima Kendaraan wajib diisi."); return; }
        if (_total <= 0)                                       { _errors.Add("Harga Total harus lebih dari 0."); return; }

        _saving = true;

        var validKelengkapan = _kelengkapan
            .Where(k => !string.IsNullOrWhiteSpace(k))
            .Select(k => k.Trim())
            .ToList();

        var (id, errors) = await Api.CreateRegistrasiPenjualanAsync(
            _noPenjualan.Trim(), _saleDate, _karyawanId, _kiosId, _mediatorId,
            _metodePenjualan, _tipePenjualan, _noMesin.Trim(), _noRangka.Trim(),
            _namaCustomer.Trim(), _address.Trim(), _phone.Trim(),
            string.IsNullOrWhiteSpace(_phone1) ? null : _phone1.Trim(),
            string.IsNullOrWhiteSpace(_phone2) ? null : _phone2.Trim(),
            _offRoad, _bbn, _discount, _total, _ambilUang, _dp, _angsuran,
            _daftarHargaLeasingId, string.IsNullOrWhiteSpace(_tenorCode) ? null : _tenorCode.Trim(),
            _serahTerimaKendaraanId.Trim(),
            string.IsNullOrWhiteSpace(_tandaTerimaSementaraId) ? null : _tandaTerimaSementaraId.Trim(),
            validKelengkapan);

        _saving = false;

        if (errors is not null) { _errors.AddRange(errors); return; }

        _notice     = $"Penjualan '{_noPenjualan}' berhasil ditambahkan.";
        _showCreate = false;
        ResetForm();
        await LoadAsync();
    }

    private void StartApprove(RegistrasiPenjualanDto reg)
    {
        _approvingId      = reg.Id;
        _approvedDiscount = reg.OriginalDiscount;
    }

    private async Task HandleApprove()
    {
        if (!_approvingId.HasValue) return;
        _errors.Clear();
        _saving = true;
        var errors = await Api.ApproveRegistrasiPenjualanAsync(_approvingId.Value, _approvedDiscount);
        _saving = false;
        if (errors is not null) { _errors.AddRange(errors); return; }
        _notice      = "Penjualan berhasil di-approve.";
        _approvingId = null;
        await LoadAsync();
    }

    private async Task HandleSetEnableToVoid(RegistrasiPenjualanDto reg, bool enable)
    {
        _errors.Clear();
        var errors = await Api.SetEnableToVoidAsync(reg.Id, enable);
        if (errors is not null) { _errors.AddRange(errors); return; }
        _notice = enable ? $"Penjualan '{reg.NoPenjualan}' diizinkan void." : $"Penjualan '{reg.NoPenjualan}' dilarang void.";
        await LoadAsync();
    }

    private async Task HandleVoid(RegistrasiPenjualanDto reg)
    {
        _errors.Clear();
        var errors = await Api.VoidRegistrasiPenjualanAsync(reg.Id);
        if (errors is not null) { _errors.AddRange(errors); return; }
        _notice = $"Penjualan '{reg.NoPenjualan}' berhasil di-void.";
        if (_viewingDetail?.Id == reg.Id) _viewingDetail = null;
        await LoadAsync();
    }

    private async Task ViewDetail(RegistrasiPenjualanDto reg)
    {
        if (_viewingDetail?.Id == reg.Id) { _viewingDetail = null; return; }
        _viewingDetail = await Api.GetRegistrasiPenjualanByIdAsync(reg.Id) ?? reg;
    }

    private void ResetForm()
    {
        _noPenjualan            = "";
        _saleDate               = DateOnly.FromDateTime(DateTime.Today);
        _karyawanId             = Guid.Empty;
        _kiosId                 = Guid.Empty;
        _mediatorId             = null;
        _metodePenjualan        = "CASH";
        _tipePenjualan          = "DIRECT";
        _noMesin                = "";
        _noRangka               = "";
        _namaCustomer           = "";
        _address                = "";
        _phone                  = "";
        _phone1                 = null;
        _phone2                 = null;
        _offRoad                = 0;
        _bbn                    = 0;
        _discount               = 0;
        _total                  = 0;
        _ambilUang              = 0;
        _dp                     = 0;
        _angsuran               = 0;
        _daftarHargaLeasingId   = null;
        _tenorCode              = null;
        _serahTerimaKendaraanId = "";
        _tandaTerimaSementaraId = null;
        _kelengkapan            = [];
    }

    // ── Display helpers ────────────────────────────────────────────────────────

    private string KaryawanName(Guid id)
        => _karyawans?.FirstOrDefault(k => k.Id == id)?.Name ?? "—";

    private string KiosCode(Guid id)
        => _kiosList?.FirstOrDefault(k => k.Id == id)?.Code ?? "—";

    private static Color StatusColor(string status) => status switch
    {
        "PENDING"  => Color.Warning,
        "APPROVED" => Color.Success,
        "SENT"     => Color.Info,
        _          => Color.Default,
    };

    private RenderFragment DetailItem(string label, string? value, bool mono = false, bool strong = false, bool wide = false) =>
        @<MudItem xs="@(wide ? 12 : 6)" sm="@(wide ? 8 : 4)" md="@(wide ? 4 : 2)">
            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">@label</MudText>
            <MudText Typo="Typo.body2"
                     Class="@(mono ? "mono" : null)"
                     Style="@(strong ? "font-weight:600" : null)">
                @(string.IsNullOrEmpty(value) ? "—" : value)
            </MudText>
        </MudItem>;
}
