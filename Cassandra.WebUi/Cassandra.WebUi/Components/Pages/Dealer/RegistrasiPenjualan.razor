@page "/dealer/registrasi-penjualan"
@attribute [Authorize(Roles = "Admin,Sales,Cashier")]
@rendermode InteractiveServer
@using Cassandra.WebUi.Services
@inject MasterDataApiClient Api

<PageTitle>Registrasi Penjualan — Cassandra</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">Registrasi Penjualan</h4>
    <AuthorizeView Roles="Admin,Sales">
        <button class="btn btn-primary" @onclick="ToggleCreate">
            <i class="bi bi-plus-lg me-1"></i>
            @(_showCreate ? "Tutup Form" : "Tambah Penjualan")
        </button>
    </AuthorizeView>
</div>

@if (_errors.Count > 0)
{
    <div class="alert alert-danger alert-dismissible">
        <ul class="mb-0 ps-3">
            @foreach (var e in _errors)
            {
                <li>@e</li>
            }
        </ul>
        <button type="button" class="btn-close" @onclick="() => _errors.Clear()"></button>
    </div>
}
@if (!string.IsNullOrEmpty(_notice))
{
    <div class="alert alert-success alert-dismissible">
        @_notice
        <button type="button" class="btn-close" @onclick="() => _notice = null"></button>
    </div>
}

@* ── Create form ── *@
@if (_showCreate)
{
    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="bi bi-plus-circle me-1"></i> Tambah Registrasi Penjualan Baru
        </div>
        <div class="card-body">
            <div class="row g-3">
                @* Left column — header *@
                <div class="col-md-6">
                    <h6 class="fw-semibold text-muted mb-3">Data Kendaraan &amp; Penjualan</h6>

                    <div class="mb-3">
                        <label class="form-label">No. Penjualan <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="_noPenjualan" placeholder="cth. PJ-2025-001" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tanggal Penjualan <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" value="@_saleDate.ToString("yyyy-MM-dd")"
                               @onchange="e => _saleDate = DateOnly.Parse(e.Value?.ToString() ?? _saleDate.ToString())" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Sales / Karyawan <span class="text-danger">*</span></label>
                        <InputSelect class="form-select" @bind-Value="_karyawanId">
                            <option value="">— Pilih Karyawan —</option>
                            @foreach (var k in (_karyawans ?? []).Where(k => k.IsActive))
                            {
                                <option value="@k.Id">@k.Name</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Kios <span class="text-danger">*</span></label>
                        <InputSelect class="form-select" @bind-Value="_kiosId">
                            <option value="">— Pilih Kios —</option>
                            @foreach (var k in (_kiosList ?? []).Where(k => k.IsActive))
                            {
                                <option value="@k.Id">@k.Code — @k.Name</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mediator <span class="text-muted small">(opsional)</span></label>
                        <InputSelect class="form-select" @bind-Value="_mediatorId">
                            <option value="">— Tanpa Mediator —</option>
                            @foreach (var m in (_mediators ?? []).Where(m => m.IsActive))
                            {
                                <option value="@m.Id">@m.Name</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">No. Mesin <span class="text-danger">*</span></label>
                        <input type="text" class="form-control font-monospace" @bind="_noMesin"
                               @bind:event="oninput"
                               @onblur="OnNoMesinBlur"
                               placeholder="Nomor mesin unit" />
                        <div class="form-text">Tab keluar untuk auto-isi No. Rangka dari stok.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">No. Rangka <span class="text-danger">*</span></label>
                        <input type="text" class="form-control font-monospace" @bind="_noRangka" placeholder="Nomor rangka unit" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Metode Penjualan <span class="text-danger">*</span></label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="metodePenjualan" id="metodeCash"
                                       value="CASH" checked="@(_metodePenjualan == "CASH")"
                                       @onchange="@(_ => OnMetodeChanged("CASH"))" />
                                <label class="form-check-label" for="metodeCash">CASH</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="metodePenjualan" id="metodeCredit"
                                       value="CREDIT" checked="@(_metodePenjualan == "CREDIT")"
                                       @onchange="@(_ => OnMetodeChanged("CREDIT"))" />
                                <label class="form-check-label" for="metodeCredit">CREDIT</label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tipe Penjualan <span class="text-danger">*</span></label>
                        <InputSelect class="form-select" @bind-Value="_tipePenjualan">
                            <option value="DIRECT">DIRECT</option>
                            <option value="KIOS">KIOS</option>
                            <option value="MEDIATOR">MEDIATOR</option>
                        </InputSelect>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">No. Serah Terima Kendaraan <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="_serahTerimaKendaraanId" placeholder="No. STK" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">No. Tanda Terima Sementara <span class="text-muted small">(opsional)</span></label>
                        <input type="text" class="form-control" @bind="_tandaTerimaSementaraId" placeholder="No. TTS" />
                    </div>
                </div>

                @* Right column — financial *@
                <div class="col-md-6">
                    <h6 class="fw-semibold text-muted mb-3">Data Finansial</h6>

                    <div class="mb-3">
                        <label class="form-label">Harga Total <span class="text-danger">*</span></label>
                        <InputNumber class="form-control" @bind-Value="_total" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Off Road</label>
                        <InputNumber class="form-control" @bind-Value="_offRoad" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">BBN</label>
                        <InputNumber class="form-control" @bind-Value="_bbn" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Diskon yang Diminta</label>
                        <InputNumber class="form-control" @bind-Value="_discount" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ambil Uang</label>
                        <InputNumber class="form-control" @bind-Value="_ambilUang" />
                    </div>

                    @if (_metodePenjualan == "CREDIT")
                    {
                        <div class="mb-3">
                            <label class="form-label">DP (Uang Muka)</label>
                            <InputNumber class="form-control" @bind-Value="_dp" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Angsuran / Bulan</label>
                            <InputNumber class="form-control" @bind-Value="_angsuran" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Daftar Harga Leasing</label>
                            <InputSelect class="form-select" @bind-Value="_daftarHargaLeasingId">
                                <option value="">— Pilih Daftar Harga Leasing —</option>
                                @foreach (var d in (_daftarHargaLeasings ?? []).Where(d => d.IsActive))
                                {
                                    <option value="@d.Id">@d.Name</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Tenor Code <span class="text-muted small">(opsional)</span></label>
                            <input type="text" class="form-control" @bind="_tenorCode" placeholder="cth. T24" />
                        </div>
                    }

                    <h6 class="fw-semibold text-muted mb-3 mt-4">Data Konsumen</h6>
                    <div class="mb-3">
                        <label class="form-label">Nama Konsumen <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="_namaCustomer" placeholder="Nama lengkap" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Alamat <span class="text-danger">*</span></label>
                        <textarea class="form-control" rows="2" @bind="_address" placeholder="Alamat lengkap"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Telepon <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="_phone" placeholder="No. telepon utama" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Telepon 1 <span class="text-muted small">(opsional)</span></label>
                        <input type="text" class="form-control" @bind="_phone1" placeholder="No. telepon alternatif" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Telepon 2 <span class="text-muted small">(opsional)</span></label>
                        <input type="text" class="form-control" @bind="_phone2" placeholder="No. telepon alternatif 2" />
                    </div>
                </div>
            </div>

            @* Kelengkapan section *@
            <div class="mt-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="fw-semibold">Kelengkapan <span class="text-muted small">(opsional)</span></span>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AddKelengkapan">
                        <i class="bi bi-plus-lg"></i> Tambah
                    </button>
                </div>
                @if (_kelengkapan.Count > 0)
                {
                    <div class="row g-2">
                        @foreach (var (item, idx) in _kelengkapan.Select((v, i) => (v, i)))
                        {
                            <div class="col-md-4">
                                <div class="input-group input-group-sm">
                                    <input type="text" class="form-control" value="@item"
                                           @onchange="e => _kelengkapan[idx] = e.Value?.ToString() ?? string.Empty"
                                           list="kelengkapan-datalist"
                                           placeholder="Nama kelengkapan" />
                                    <button type="button" class="btn btn-outline-danger"
                                            @onclick="() => RemoveKelengkapan(idx)">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                    <datalist id="kelengkapan-datalist">
                        @foreach (var k in (_kelengkapans ?? []).Where(k => k.IsActive))
                        {
                            <option value="@k.Name">@k.Name</option>
                        }
                    </datalist>
                }
            </div>

            <div class="mt-4">
                <button type="button" class="btn btn-primary" @onclick="HandleCreate" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    else
                    {
                        <i class="bi bi-check-lg me-1"></i>
                    }
                    Simpan Penjualan
                </button>
                <button type="button" class="btn btn-outline-secondary ms-2" @onclick="ToggleCreate">Batal</button>
            </div>
        </div>
    </div>
}

@* ── Approve inline form ── *@
@if (_approvingId.HasValue)
{
    <div class="card mb-4 border-warning">
        <div class="card-header fw-semibold text-warning-emphasis bg-warning-subtle d-flex justify-content-between align-items-center">
            <span><i class="bi bi-check-circle me-1"></i> Approve Penjualan</span>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _approvingId = null">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Diskon yang Disetujui <span class="text-danger">*</span></label>
                    <InputNumber class="form-control" @bind-Value="_approvedDiscount" />
                </div>
                <div class="col-md-3">
                    <button type="button" class="btn btn-warning" @onclick="HandleApprove" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Simpan Approve
                    </button>
                    <button type="button" class="btn btn-outline-secondary ms-2" @onclick="() => _approvingId = null">Batal</button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Detail view ── *@
@if (_viewingDetail is not null)
{
    <div class="card mb-4 border-info">
        <div class="card-header fw-semibold text-info-emphasis bg-info-subtle d-flex justify-content-between align-items-center">
            <span><i class="bi bi-eye me-1"></i> Detail — @_viewingDetail.NoPenjualan</span>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _viewingDetail = null">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="card-body">
            <div class="row mb-3 small">
                <div class="col-md-2">
                    <div class="text-muted">No. Penjualan</div>
                    <div class="fw-semibold">@_viewingDetail.NoPenjualan</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted">Tanggal</div>
                    <div>@_viewingDetail.SaleDate.ToString("dd/MM/yyyy")</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted">Metode</div>
                    <div>@_viewingDetail.MetodePenjualan</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted">Tipe</div>
                    <div>@_viewingDetail.TipePenjualan</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted">No. Mesin</div>
                    <div class="font-monospace">@_viewingDetail.NoMesin</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted">No. Rangka</div>
                    <div class="font-monospace">@_viewingDetail.NoRangka</div>
                </div>
            </div>
            <div class="row mb-3 small">
                <div class="col-md-3">
                    <div class="text-muted">Nama Konsumen</div>
                    <div class="fw-semibold">@_viewingDetail.NamaCustomer</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted">Alamat</div>
                    <div>@_viewingDetail.Address</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted">Telepon</div>
                    <div>@_viewingDetail.Phone</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted">Tipe Motor</div>
                    <div>@_viewingDetail.TipeMotorCode</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted">Warna</div>
                    <div>@_viewingDetail.WarnaName</div>
                </div>
            </div>
            <div class="row mb-3 small">
                <div class="col-md-2">
                    <div class="text-muted">Total</div>
                    <div class="fw-semibold">@_viewingDetail.Total.ToString("N0")</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted">Off Road</div>
                    <div>@_viewingDetail.OffRoad.ToString("N0")</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted">BBN</div>
                    <div>@_viewingDetail.Bbn.ToString("N0")</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted">Diskon</div>
                    <div>@_viewingDetail.Discount.ToString("N0")</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted">Diskon Disetujui</div>
                    <div>@_viewingDetail.ApprovedDiscount.ToString("N0")</div>
                </div>
                <div class="col-md-2">
                    <div class="text-muted">TAC</div>
                    <div>@_viewingDetail.Tac.ToString("N0")</div>
                </div>
            </div>
            @if (_viewingDetail.MetodePenjualan == "CREDIT")
            {
                <div class="row mb-3 small">
                    <div class="col-md-2">
                        <div class="text-muted">DP</div>
                        <div>@_viewingDetail.Dp.ToString("N0")</div>
                    </div>
                    <div class="col-md-2">
                        <div class="text-muted">Angsuran</div>
                        <div>@_viewingDetail.Angsuran.ToString("N0")</div>
                    </div>
                    <div class="col-md-2">
                        <div class="text-muted">Tenor</div>
                        <div>@(_viewingDetail.TenorCode ?? "—")</div>
                    </div>
                </div>
            }
            @if (_viewingDetail.Kelengkapan is { Count: > 0 })
            {
                <div class="mb-2 small">
                    <div class="text-muted mb-1">Kelengkapan</div>
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var k in _viewingDetail.Kelengkapan)
                        {
                            <span class="badge bg-secondary">@k</span>
                        }
                    </div>
                </div>
            }
            <div class="row small">
                <div class="col-md-3">
                    <div class="text-muted">No. STK</div>
                    <div>@_viewingDetail.SerahTerimaKendaraanId</div>
                </div>
                @if (_viewingDetail.TandaTerimaSementaraId is not null)
                {
                    <div class="col-md-3">
                        <div class="text-muted">No. TTS</div>
                        <div>@_viewingDetail.TandaTerimaSementaraId</div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@* ── List table ── *@
<div class="card">
    <div class="card-header fw-semibold">Semua Registrasi Penjualan</div>
    <div class="card-body p-0">
        @if (_list is null)
        {
            <div class="p-3 text-muted">
                <span class="spinner-border spinner-border-sm me-1"></span> Memuat…
            </div>
        }
        else if (_list.Count == 0)
        {
            <div class="p-3 text-muted">Belum ada registrasi penjualan yang terdaftar.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>No. Penjualan</th>
                            <th>Tgl</th>
                            <th>Sales</th>
                            <th>Kios</th>
                            <th>Metode</th>
                            <th>No. Mesin</th>
                            <th>Nama Konsumen</th>
                            <th class="text-end">Total</th>
                            <th>Status</th>
                            <th class="text-end">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reg in _list)
                        {
                            <tr class="@(_viewingDetail?.Id == reg.Id ? "table-info" : "")">
                                <td class="fw-semibold">@reg.NoPenjualan</td>
                                <td>@reg.SaleDate.ToString("dd/MM/yyyy")</td>
                                <td class="small">@KaryawanName(reg.KaryawanId)</td>
                                <td class="small">@KiosCode(reg.KiosId)</td>
                                <td><span class="badge @(reg.MetodePenjualan == "CREDIT" ? "bg-info text-dark" : "bg-primary")">@reg.MetodePenjualan</span></td>
                                <td class="font-monospace small">@reg.NoMesin</td>
                                <td>@reg.NamaCustomer</td>
                                <td class="text-end">@reg.Total.ToString("N0")</td>
                                <td>@StatusBadge(reg.Status)</td>
                                <td class="text-end">
                                    <div class="d-flex gap-1 justify-content-end flex-wrap">
                                        <button class="btn btn-sm btn-outline-info" title="Detail"
                                                @onclick="() => ViewDetail(reg)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <AuthorizeView Roles="Admin">
                                            @if (reg.Status == "PENDING")
                                            {
                                                <button class="btn btn-sm btn-outline-success" title="Approve"
                                                        @onclick="() => StartApprove(reg)">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            }
                                            @if (reg.EnableToVoid)
                                            {
                                                <button class="btn btn-sm btn-outline-secondary" title="Larang Void"
                                                        @onclick="() => HandleSetEnableToVoid(reg, false)">
                                                    <i class="bi bi-shield-x"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-secondary" title="Izinkan Void"
                                                        @onclick="() => HandleSetEnableToVoid(reg, true)">
                                                    <i class="bi bi-shield-check"></i>
                                                </button>
                                            }
                                            @if (reg.Status != "VOID" && reg.EnableToVoid)
                                            {
                                                <button class="btn btn-sm btn-outline-danger" title="Void"
                                                        @onclick="() => HandleVoid(reg)">
                                                    <i class="bi bi-slash-circle"></i>
                                                </button>
                                            }
                                        </AuthorizeView>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<RegistrasiPenjualanDto>? _list;
    private List<KaryawanDto>?            _karyawans;
    private List<KiosDto>?                _kiosList;
    private List<MediatorDto>?            _mediators;
    private List<KelengkapanDto>?         _kelengkapans;
    private List<DaftarHargaLeasingDto>?  _daftarHargaLeasings;
    private bool                          _showCreate;
    private bool                          _saving;
    private readonly List<string>         _errors = [];
    private string?                       _notice;
    private RegistrasiPenjualanDto?       _viewingDetail;

    // Form fields
    private string     _noPenjualan            = "";
    private DateOnly   _saleDate               = DateOnly.FromDateTime(DateTime.Today);
    private Guid       _karyawanId;
    private Guid       _kiosId;
    private Guid?      _mediatorId;
    private string     _metodePenjualan        = "CASH";
    private string     _tipePenjualan          = "DIRECT";
    private string     _noMesin                = "";
    private string     _noRangka               = "";
    private string     _namaCustomer           = "";
    private string     _address                = "";
    private string     _phone                  = "";
    private string?    _phone1;
    private string?    _phone2;
    private decimal    _offRoad;
    private decimal    _bbn;
    private decimal    _discount;
    private decimal    _total;
    private decimal    _ambilUang;
    private decimal    _dp;
    private decimal    _angsuran;
    private Guid?      _daftarHargaLeasingId;
    private string?    _tenorCode;
    private string     _serahTerimaKendaraanId = "";
    private string?    _tandaTerimaSementaraId;
    private List<string> _kelengkapan          = [];

    // Approve inline state
    private Guid?   _approvingId;
    private decimal _approvedDiscount;

    // ── Lifecycle ──────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        var listTask    = Api.GetRegistrasiPenjualansAsync();
        var karyTask    = Api.GetKaryawanAsync();
        var kiosTask    = Api.GetKiosAsync();
        var medTask     = Api.GetMediatorsAsync();
        var klTask      = Api.GetKelengkapanAsync();
        var dhlTask     = Api.GetDaftarHargaLeasingAsync();
        await Task.WhenAll(listTask, karyTask, kiosTask, medTask, klTask, dhlTask);
        _list                = listTask.Result  ?? [];
        _karyawans           = karyTask.Result  ?? [];
        _kiosList            = kiosTask.Result  ?? [];
        _mediators           = medTask.Result   ?? [];
        _kelengkapans        = klTask.Result    ?? [];
        _daftarHargaLeasings = dhlTask.Result   ?? [];
    }

    private async Task LoadAsync()
        => _list = await Api.GetRegistrasiPenjualansAsync() ?? [];

    // ── Actions ────────────────────────────────────────────────────────────────

    private void ToggleCreate()
    {
        _showCreate = !_showCreate;
        if (!_showCreate) ResetForm();
    }

    private void OnMetodeChanged(string metode)
    {
        _metodePenjualan = metode;
        if (metode == "CASH")
        {
            _dp                   = 0;
            _angsuran             = 0;
            _daftarHargaLeasingId = null;
            _tenorCode            = null;
        }
    }

    private async Task OnNoMesinBlur()
    {
        if (string.IsNullOrWhiteSpace(_noMesin) || _kiosId == Guid.Empty)
            return;

        var stocks = await Api.GetStocksByKiosAsync(_kiosId);
        var match  = stocks?.FirstOrDefault(s =>
            s.NoMesin.Equals(_noMesin.Trim(), StringComparison.OrdinalIgnoreCase));
        if (match is not null)
        {
            _noRangka = match.NoRangka;
        }
    }

    private void AddKelengkapan()    => _kelengkapan.Add("");
    private void RemoveKelengkapan(int idx) => _kelengkapan.RemoveAt(idx);

    private async Task HandleCreate()
    {
        _errors.Clear();

        if (string.IsNullOrWhiteSpace(_noPenjualan))          { _errors.Add("No. Penjualan wajib diisi."); return; }
        if (_karyawanId == Guid.Empty)                         { _errors.Add("Karyawan wajib dipilih."); return; }
        if (_kiosId == Guid.Empty)                             { _errors.Add("Kios wajib dipilih."); return; }
        if (string.IsNullOrWhiteSpace(_noMesin))              { _errors.Add("No. Mesin wajib diisi."); return; }
        if (string.IsNullOrWhiteSpace(_noRangka))             { _errors.Add("No. Rangka wajib diisi."); return; }
        if (string.IsNullOrWhiteSpace(_namaCustomer))         { _errors.Add("Nama Konsumen wajib diisi."); return; }
        if (string.IsNullOrWhiteSpace(_address))              { _errors.Add("Alamat wajib diisi."); return; }
        if (string.IsNullOrWhiteSpace(_phone))                { _errors.Add("Telepon wajib diisi."); return; }
        if (string.IsNullOrWhiteSpace(_serahTerimaKendaraanId)) { _errors.Add("No. Serah Terima Kendaraan wajib diisi."); return; }
        if (_total <= 0)                                       { _errors.Add("Harga Total harus lebih dari 0."); return; }

        _saving = true;

        var validKelengkapan = _kelengkapan
            .Where(k => !string.IsNullOrWhiteSpace(k))
            .Select(k => k.Trim())
            .ToList();

        var (id, errors) = await Api.CreateRegistrasiPenjualanAsync(
            _noPenjualan.Trim(), _saleDate, _karyawanId, _kiosId, _mediatorId,
            _metodePenjualan, _tipePenjualan, _noMesin.Trim(), _noRangka.Trim(),
            _namaCustomer.Trim(), _address.Trim(), _phone.Trim(),
            string.IsNullOrWhiteSpace(_phone1) ? null : _phone1.Trim(),
            string.IsNullOrWhiteSpace(_phone2) ? null : _phone2.Trim(),
            _offRoad, _bbn, _discount, _total, _ambilUang, _dp, _angsuran,
            _daftarHargaLeasingId, string.IsNullOrWhiteSpace(_tenorCode) ? null : _tenorCode.Trim(),
            _serahTerimaKendaraanId.Trim(),
            string.IsNullOrWhiteSpace(_tandaTerimaSementaraId) ? null : _tandaTerimaSementaraId.Trim(),
            validKelengkapan);

        _saving = false;

        if (errors is not null) { _errors.AddRange(errors); return; }

        _notice     = $"Penjualan '{_noPenjualan}' berhasil ditambahkan.";
        _showCreate = false;
        ResetForm();
        await LoadAsync();
    }

    private void StartApprove(RegistrasiPenjualanDto reg)
    {
        _approvingId      = reg.Id;
        _approvedDiscount = reg.OriginalDiscount;
    }

    private async Task HandleApprove()
    {
        if (!_approvingId.HasValue) return;
        _errors.Clear();
        _saving = true;
        var errors = await Api.ApproveRegistrasiPenjualanAsync(_approvingId.Value, _approvedDiscount);
        _saving = false;
        if (errors is not null) { _errors.AddRange(errors); return; }
        _notice      = "Penjualan berhasil di-approve.";
        _approvingId = null;
        await LoadAsync();
    }

    private async Task HandleSetEnableToVoid(RegistrasiPenjualanDto reg, bool enable)
    {
        _errors.Clear();
        var errors = await Api.SetEnableToVoidAsync(reg.Id, enable);
        if (errors is not null) { _errors.AddRange(errors); return; }
        _notice = enable ? $"Penjualan '{reg.NoPenjualan}' diizinkan void." : $"Penjualan '{reg.NoPenjualan}' dilarang void.";
        await LoadAsync();
    }

    private async Task HandleVoid(RegistrasiPenjualanDto reg)
    {
        _errors.Clear();
        var errors = await Api.VoidRegistrasiPenjualanAsync(reg.Id);
        if (errors is not null) { _errors.AddRange(errors); return; }
        _notice = $"Penjualan '{reg.NoPenjualan}' berhasil di-void.";
        if (_viewingDetail?.Id == reg.Id) _viewingDetail = null;
        await LoadAsync();
    }

    private async Task ViewDetail(RegistrasiPenjualanDto reg)
    {
        if (_viewingDetail?.Id == reg.Id) { _viewingDetail = null; return; }
        _viewingDetail = await Api.GetRegistrasiPenjualanByIdAsync(reg.Id) ?? reg;
    }

    private void ResetForm()
    {
        _noPenjualan            = "";
        _saleDate               = DateOnly.FromDateTime(DateTime.Today);
        _karyawanId             = Guid.Empty;
        _kiosId                 = Guid.Empty;
        _mediatorId             = null;
        _metodePenjualan        = "CASH";
        _tipePenjualan          = "DIRECT";
        _noMesin                = "";
        _noRangka               = "";
        _namaCustomer           = "";
        _address                = "";
        _phone                  = "";
        _phone1                 = null;
        _phone2                 = null;
        _offRoad                = 0;
        _bbn                    = 0;
        _discount               = 0;
        _total                  = 0;
        _ambilUang              = 0;
        _dp                     = 0;
        _angsuran               = 0;
        _daftarHargaLeasingId   = null;
        _tenorCode              = null;
        _serahTerimaKendaraanId = "";
        _tandaTerimaSementaraId = null;
        _kelengkapan            = [];
    }

    // ── Display helpers ────────────────────────────────────────────────────────

    private string KaryawanName(Guid id)
        => _karyawans?.FirstOrDefault(k => k.Id == id)?.Name ?? "—";

    private string KiosCode(Guid id)
        => _kiosList?.FirstOrDefault(k => k.Id == id)?.Code ?? "—";

    private RenderFragment StatusBadge(string status) => status switch
    {
        "PENDING"  => @<span class="badge bg-warning text-dark">PENDING</span>,
        "APPROVED" => @<span class="badge bg-success">APPROVED</span>,
        "SENT"     => @<span class="badge bg-info text-dark">SENT</span>,
        "VOID"     => @<span class="badge bg-secondary">VOID</span>,
        _          => @<span class="badge bg-secondary">@status</span>,
    };
}
