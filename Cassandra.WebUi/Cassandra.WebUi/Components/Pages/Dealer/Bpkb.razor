@page "/dealer/bpkb"
@attribute [Authorize(Roles = "Admin,Sales,Cashier")]
@rendermode InteractiveServer
@using Cassandra.WebUi.Services
@inject MasterDataApiClient Api

<PageTitle>BPKB — Cassandra</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">BPKB</h4>
</div>

@if (_errors.Count > 0)
{
    <div class="alert alert-danger alert-dismissible">
        <ul class="mb-0 ps-3">
            @foreach (var e in _errors)
            {
                <li>@e</li>
            }
        </ul>
        <button type="button" class="btn-close" @onclick="() => _errors.Clear()"></button>
    </div>
}
@if (!string.IsNullOrEmpty(_notice))
{
    <div class="alert alert-success alert-dismissible">
        @_notice
        <button type="button" class="btn-close" @onclick="() => _notice = null"></button>
    </div>
}

@* ── List table ── *@
<div class="card">
    <div class="card-header fw-semibold">Semua BPKB</div>
    <div class="card-body p-0">
        @if (_list is null)
        {
            <div class="p-3 text-muted">
                <span class="spinner-border spinner-border-sm me-1"></span> Memuat…
            </div>
        }
        else if (_list.Count == 0)
        {
            <div class="p-3 text-muted">Belum ada data BPKB.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>No. Penjualan</th>
                            <th>Tgl Permintaan</th>
                            <th>No. BPKB</th>
                            <th>No. Buku</th>
                            <th>Tgl Terima</th>
                            <th>Tgl Serah</th>
                            <th>Penerima</th>
                            <th>Status</th>
                            <th class="text-end">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _list)
                        {
                            var reg = _registrasis?.FirstOrDefault(r => r.Id == item.RegistrasiPenjualanId);
                            <tr>
                                <td class="fw-semibold">@(reg?.NoPenjualan ?? "—")</td>
                                <td>@item.RequestDate.ToString("dd/MM/yyyy")</td>
                                <td class="font-monospace small">@(item.BpkbNumber ?? "—")</td>
                                <td class="font-monospace small">@(item.BookNumber ?? "—")</td>
                                <td>@(item.ReceiveDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td>@(item.HandoverDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td>@(item.Receiver ?? "—")</td>
                                <td>@BpkbStatusBadge(item.Status)</td>
                                <td class="text-end">
                                    <AuthorizeView Roles="Admin,Sales">
                                        <div class="d-flex gap-1 justify-content-end flex-wrap">
                                            @if (item.Status == "REQUEST")
                                            {
                                                <button class="btn btn-sm btn-outline-primary"
                                                        title="Terima BPKB"
                                                        @onclick="() => StartReceive(item.Id)">
                                                    <i class="bi bi-inbox"></i> Terima BPKB
                                                </button>
                                            }
                                            @if (item.Status == "RECEIVE")
                                            {
                                                <button class="btn btn-sm btn-outline-success"
                                                        title="Serah Terima"
                                                        @onclick="() => StartHandover(item.Id)">
                                                    <i class="bi bi-box-arrow-right"></i> Serah Terima
                                                </button>
                                            }
                                        </div>
                                    </AuthorizeView>
                                </td>
                            </tr>
                            @* ── Inline action rows ── *@
                            @if (_actionRowId == item.Id && _actionType == ActionReceive)
                            {
                                <tr class="table-primary">
                                    <td colspan="9">
                                        <div class="p-3">
                                            <h6 class="fw-semibold mb-3">
                                                <i class="bi bi-inbox me-1"></i> Terima BPKB
                                            </h6>
                                            <div class="row g-3 align-items-end">
                                                <div class="col-md-3">
                                                    <label class="form-label">Tanggal Terima <span class="text-danger">*</span></label>
                                                    <input type="date" class="form-control"
                                                           value="@_receiveDate.ToString("yyyy-MM-dd")"
                                                           @onchange="e => _receiveDate = DateOnly.Parse(e.Value?.ToString() ?? _receiveDate.ToString())" />
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">No. BPKB <span class="text-danger">*</span></label>
                                                    <input type="text" class="form-control font-monospace" @bind="_bpkbNumber" placeholder="No. BPKB" />
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">No. Buku <span class="text-danger">*</span></label>
                                                    <input type="text" class="form-control font-monospace" @bind="_bookNumber" placeholder="No. buku" />
                                                </div>
                                                <div class="col-md-3">
                                                    <button type="button" class="btn btn-primary" @onclick="() => HandleReceive(item.Id)" disabled="@_saving">
                                                        @if (_saving)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                                        }
                                                        Simpan Terima
                                                    </button>
                                                    <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CollapseAction">Batal</button>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (_actionRowId == item.Id && _actionType == ActionHandover)
                            {
                                <tr class="table-success">
                                    <td colspan="9">
                                        <div class="p-3">
                                            <h6 class="fw-semibold mb-3">
                                                <i class="bi bi-box-arrow-right me-1"></i> Serah Terima BPKB
                                            </h6>
                                            <div class="row g-3 align-items-end">
                                                <div class="col-md-3">
                                                    <label class="form-label">Tanggal Serah Terima <span class="text-danger">*</span></label>
                                                    <input type="date" class="form-control"
                                                           value="@_handoverDate.ToString("yyyy-MM-dd")"
                                                           @onchange="e => _handoverDate = DateOnly.Parse(e.Value?.ToString() ?? _handoverDate.ToString())" />
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">Penerima <span class="text-danger">*</span></label>
                                                    <input type="text" class="form-control" @bind="_receiver" placeholder="Nama penerima BPKB" />
                                                </div>
                                                <div class="col-md-3">
                                                    <button type="button" class="btn btn-success" @onclick="() => HandleHandover(item.Id)" disabled="@_saving">
                                                        @if (_saving)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                                        }
                                                        Simpan Serah Terima
                                                    </button>
                                                    <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CollapseAction">Batal</button>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    // Action type constants
    private const string ActionReceive  = "receive";
    private const string ActionHandover = "handover";

    private List<BpkbDto>?                _list;
    private List<RegistrasiPenjualanDto>? _registrasis;
    private bool                          _saving;
    private readonly List<string>         _errors = [];
    private string?                       _notice;

    private Guid?   _actionRowId;
    private string? _actionType;

    // Receive inline fields
    private DateOnly _receiveDate = DateOnly.FromDateTime(DateTime.Today);
    private string   _bpkbNumber  = "";
    private string   _bookNumber  = "";

    // Handover inline fields
    private DateOnly _handoverDate = DateOnly.FromDateTime(DateTime.Today);
    private string   _receiver     = "";

    // ── Lifecycle ──────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        var listTask = Api.GetBpkbsAsync();
        var regTask  = Api.GetRegistrasiPenjualansAsync();
        await Task.WhenAll(listTask, regTask);
        _list        = listTask.Result ?? [];
        _registrasis = regTask.Result  ?? [];
    }

    private async Task LoadAsync()
        => _list = await Api.GetBpkbsAsync() ?? [];

    // ── Actions ────────────────────────────────────────────────────────────────

    private void StartReceive(Guid rowId)
        => ToggleAction(rowId, ActionReceive);

    private void StartHandover(Guid rowId)
        => ToggleAction(rowId, ActionHandover);

    private void CollapseAction()
    {
        _actionRowId = null;
        _actionType  = null;
    }

    private void ToggleAction(Guid rowId, string actionType)
    {
        if (_actionRowId == rowId && _actionType == actionType)
        {
            _actionRowId = null;
            _actionType  = null;
        }
        else
        {
            _actionRowId = rowId;
            _actionType  = actionType;
        }
    }

    private async Task HandleReceive(Guid bpkbId)
    {
        _errors.Clear();
        if (string.IsNullOrWhiteSpace(_bpkbNumber)) { _errors.Add("No. BPKB wajib diisi."); return; }
        if (string.IsNullOrWhiteSpace(_bookNumber))  { _errors.Add("No. Buku wajib diisi."); return; }

        _saving = true;
        var errors = await Api.ReceiveBpkbAsync(bpkbId, _receiveDate, _bpkbNumber.Trim(), _bookNumber.Trim());
        _saving = false;

        if (errors is not null) { _errors.AddRange(errors); return; }

        _notice      = "BPKB berhasil diterima.";
        CollapseAction();
        _receiveDate = DateOnly.FromDateTime(DateTime.Today);
        _bpkbNumber  = "";
        _bookNumber  = "";
        await LoadAsync();
    }

    private async Task HandleHandover(Guid bpkbId)
    {
        _errors.Clear();
        if (string.IsNullOrWhiteSpace(_receiver)) { _errors.Add("Penerima wajib diisi."); return; }

        _saving = true;
        var errors = await Api.HandoverBpkbAsync(bpkbId, _handoverDate, _receiver.Trim());
        _saving = false;

        if (errors is not null) { _errors.AddRange(errors); return; }

        _notice       = "Serah terima BPKB berhasil disimpan.";
        CollapseAction();
        _handoverDate = DateOnly.FromDateTime(DateTime.Today);
        _receiver     = "";
        await LoadAsync();
    }

    // ── Display helpers ────────────────────────────────────────────────────────

    private RenderFragment BpkbStatusBadge(string status) => status switch
    {
        "REQUEST"  => @<span class="badge bg-warning text-dark">REQUEST</span>,
        "RECEIVE"  => @<span class="badge bg-info text-dark">RECEIVE</span>,
        "HANDOVER" => @<span class="badge bg-success">HANDOVER</span>,
        _          => @<span class="badge bg-secondary">@status</span>,
    };
}
