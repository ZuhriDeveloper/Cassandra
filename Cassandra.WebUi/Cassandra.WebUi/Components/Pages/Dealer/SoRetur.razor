@page "/dealer/so-retur"
@attribute [Authorize(Roles = "Admin,Sales,Cashier")]
@rendermode InteractiveServer
@using Cassandra.WebUi.Services
@inject MasterDataApiClient Api

<PageTitle>Retur SO — Cassandra</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">Retur SO</h4>
    <button class="btn btn-primary" @onclick="ToggleCreate">
        <i class="bi bi-plus-lg me-1"></i>
        @(_showCreate ? "Tutup Form" : "Tambah Retur")
    </button>
</div>

@if (_errors.Count > 0)
{
    <div class="alert alert-danger alert-dismissible">
        <ul class="mb-0 ps-3">
            @foreach (var e in _errors)
            {
                <li>@e</li>
            }
        </ul>
        <button type="button" class="btn-close" @onclick="() => _errors.Clear()"></button>
    </div>
}
@if (!string.IsNullOrEmpty(_notice))
{
    <div class="alert alert-success alert-dismissible">
        @_notice
        <button type="button" class="btn-close" @onclick="() => _notice = null"></button>
    </div>
}

@* ── Create form ── *@
@if (_showCreate)
{
    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="bi bi-plus-circle me-1"></i> Tambah Retur SO Baru
        </div>
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label class="form-label">No. Retur <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" @bind="_returNumber" placeholder="cth. RTR-2025-001" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">SO <span class="text-danger">*</span></label>
                    <InputSelect class="form-select" @bind-Value="_soId">
                        <option value="">— Pilih SO —</option>
                        @foreach (var so in (_soList ?? []))
                        {
                            <option value="@so.Id">@so.SoNumber (@so.SoDate.ToString("dd/MM/yyyy"))</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Tanggal Retur <span class="text-danger">*</span></label>
                    <input type="date" class="form-control" value="@_returDate.ToString("yyyy-MM-dd")"
                           @onchange="e => _returDate = DateOnly.Parse(e.Value?.ToString() ?? _returDate.ToString())" />
                </div>
                <div class="col-12">
                    <label class="form-label">Alasan <span class="text-danger">*</span></label>
                    <textarea class="form-control" rows="2" @bind="_reason" placeholder="Alasan retur…"></textarea>
                </div>
            </div>

            @* Item rows *@
            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="fw-semibold">Item Retur <span class="text-danger">*</span></span>
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddItem">
                        <i class="bi bi-plus-lg"></i> Tambah Baris
                    </button>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Tipe Motor</th>
                                <th>Warna</th>
                                <th style="width:90px">Qty</th>
                                <th style="width:160px">Harga Nett</th>
                                <th style="width:40px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (row, idx) in _items.Select((r, i) => (r, i)))
                            {
                                <tr>
                                    <td>
                                        <InputSelect class="form-select form-select-sm"
                                                     Value="row.TipeMotorId"
                                                     ValueChanged="(Guid id) => OnTipeMotorChanged(row, id)"
                                                     ValueExpression="() => row.TipeMotorId">
                                            <option value="">— Pilih —</option>
                                            @foreach (var t in (_tipeMotors ?? []).Where(t => t.IsActive))
                                            {
                                                <option value="@t.Id">@t.Code — @t.ShortName</option>
                                            }
                                        </InputSelect>
                                    </td>
                                    <td>
                                        <InputSelect class="form-select form-select-sm" @bind-Value="row.WarnaId">
                                            <option value="">— Pilih —</option>
                                            @foreach (var w in GetWarnasForTipeMotor(row.TipeMotorId))
                                            {
                                                <option value="@w.Id">@w.Name</option>
                                            }
                                        </InputSelect>
                                    </td>
                                    <td>
                                        <InputNumber class="form-control form-control-sm" @bind-Value="row.Qty" />
                                    </td>
                                    <td>
                                        <InputNumber class="form-control form-control-sm" @bind-Value="row.NettPrice" />
                                    </td>
                                    <td>
                                        @if (_items.Count > 1)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => RemoveItem(idx)">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @* Financial summary *@
            <div class="card bg-light mb-3">
                <div class="card-body py-2">
                    <div class="row text-end small">
                        <div class="col-4">
                            <div class="text-muted">Total</div>
                            <div class="fw-semibold">@ComputedTotal.ToString("N0")</div>
                        </div>
                        <div class="col-4">
                            <div class="text-muted">PPn (10%)</div>
                            <div class="fw-semibold">@ComputedPPn.ToString("N0")</div>
                        </div>
                        <div class="col-4">
                            <div class="text-muted fw-bold">Total Amount</div>
                            <div class="fw-bold fs-6">@ComputedTotalAmount.ToString("N0")</div>
                        </div>
                    </div>
                </div>
            </div>

            <button type="button" class="btn btn-primary" @onclick="HandleCreate" disabled="@_saving">
                @if (_saving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                else
                {
                    <i class="bi bi-check-lg me-1"></i>
                }
                Simpan Retur
            </button>
            <button type="button" class="btn btn-outline-secondary ms-2" @onclick="ToggleCreate">Batal</button>
        </div>
    </div>
}

@* ── List table ── *@
<div class="card">
    <div class="card-header fw-semibold">Semua Retur SO</div>
    <div class="card-body p-0">
        @if (_list is null)
        {
            <div class="p-3 text-muted">
                <span class="spinner-border spinner-border-sm me-1"></span> Memuat…
            </div>
        }
        else if (_list.Count == 0)
        {
            <div class="p-3 text-muted">Belum ada retur SO yang terdaftar.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>No. Retur</th>
                            <th>Tgl Retur</th>
                            <th>No. SO</th>
                            <th class="text-end">Total</th>
                            <th class="text-end">PPn</th>
                            <th class="text-end">Total Amt</th>
                            <th>Alasan</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _list)
                        {
                            <tr>
                                <td class="fw-semibold">@item.ReturNumber</td>
                                <td>@item.ReturDate.ToString("dd/MM/yyyy")</td>
                                <td>@SoNumber(item.SoId)</td>
                                <td class="text-end">@item.Total.ToString("N0")</td>
                                <td class="text-end">@item.PPn.ToString("N0")</td>
                                <td class="text-end fw-semibold">@item.TotalAmount.ToString("N0")</td>
                                <td class="small text-muted" style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                                    @item.Reason
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<SoReturDto>?   _list;
    private List<SoDto>?        _soList;
    private List<TipeMotorDto>? _tipeMotors;
    private List<WarnaDto>?     _warnas;
    private bool                _showCreate;
    private bool                _saving;
    private readonly List<string> _errors = [];
    private string?             _notice;

    // ── Create form state ──────────────────────────────────────────────────────

    private sealed class ReturItemRow
    {
        public Guid    TipeMotorId { get; set; }
        public Guid    WarnaId     { get; set; }
        public int     Qty         { get; set; } = 1;
        public decimal NettPrice   { get; set; }
    }

    private string          _returNumber = "";
    private Guid            _soId;
    private DateOnly        _returDate   = DateOnly.FromDateTime(DateTime.Today);
    private string          _reason      = "";
    private List<ReturItemRow> _items    = [new ReturItemRow()];

    // ── Computed financials ────────────────────────────────────────────────────

    private decimal ComputedTotal       => _items.Sum(i => i.Qty * i.NettPrice);
    private decimal ComputedPPn         => ComputedTotal * 0.1m;
    private decimal ComputedTotalAmount => ComputedTotal + ComputedPPn;

    // ── Lifecycle ──────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        var listTask = Api.GetSoReturnsAsync();
        var soTask   = Api.GetSosAsync();
        var tipeTask = Api.GetTipeMotorAsync();
        var warnaTask = Api.GetWarnaAsync();
        await Task.WhenAll(listTask, soTask, tipeTask, warnaTask);
        _list       = listTask.Result  ?? [];
        _soList     = soTask.Result    ?? [];
        _tipeMotors = tipeTask.Result  ?? [];
        _warnas     = warnaTask.Result ?? [];
    }

    private async Task LoadAsync()
        => _list = await Api.GetSoReturnsAsync() ?? [];

    // ── Actions ────────────────────────────────────────────────────────────────

    private void ToggleCreate()
    {
        _showCreate = !_showCreate;
        if (!_showCreate) ResetForm();
    }

    private void AddItem()            => _items.Add(new ReturItemRow());
    private void RemoveItem(int idx)  => _items.RemoveAt(idx);

    private void OnTipeMotorChanged(ReturItemRow row, Guid id)
    {
        row.TipeMotorId = id;
        row.WarnaId     = Guid.Empty;
    }

    private IEnumerable<WarnaDto> GetWarnasForTipeMotor(Guid tipeMotorId)
    {
        if (_tipeMotors is null || _warnas is null || tipeMotorId == Guid.Empty) return [];
        var tipe = _tipeMotors.FirstOrDefault(t => t.Id == tipeMotorId);
        if (tipe is null) return [];
        return _warnas.Where(w => tipe.WarnaIds.Contains(w.Id) && w.IsActive);
    }

    private async Task HandleCreate()
    {
        _errors.Clear();

        if (string.IsNullOrWhiteSpace(_returNumber))           { _errors.Add("No. Retur wajib diisi.");       return; }
        if (_soId == Guid.Empty)                               { _errors.Add("SO wajib dipilih.");            return; }
        if (string.IsNullOrWhiteSpace(_reason))                { _errors.Add("Alasan wajib diisi.");          return; }
        if (_items.Count == 0)                                 { _errors.Add("Minimal 1 item wajib diisi.");  return; }
        if (_items.Any(i => i.TipeMotorId == Guid.Empty))     { _errors.Add("Semua item harus memiliki Tipe Motor."); return; }
        if (_items.Any(i => i.WarnaId == Guid.Empty))         { _errors.Add("Semua item harus memiliki Warna.");      return; }
        if (_items.Any(i => i.Qty <= 0))                      { _errors.Add("Qty harus lebih dari 0.");      return; }

        _saving = true;

        var requests = _items
            .Select(i => new SoReturItemRequest(i.TipeMotorId, i.WarnaId, i.Qty, i.NettPrice))
            .ToList();

        var (id, errors) = await Api.CreateSoReturAsync(
            _returNumber.Trim(), _soId, _returDate, _reason.Trim(), requests);

        _saving = false;

        if (errors is not null) { _errors.AddRange(errors); return; }

        _notice     = $"Retur '{_returNumber}' berhasil ditambahkan.";
        _showCreate = false;
        ResetForm();
        await LoadAsync();
    }

    private void ResetForm()
    {
        _returNumber = "";
        _soId        = Guid.Empty;
        _returDate   = DateOnly.FromDateTime(DateTime.Today);
        _reason      = "";
        _items       = [new ReturItemRow()];
    }

    private string SoNumber(Guid id)
        => _soList?.FirstOrDefault(s => s.Id == id)?.SoNumber ?? id.ToString()[..8];
}
