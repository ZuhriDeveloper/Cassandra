@page "/dealer/cabang-leasing"
@attribute [Authorize(Roles = "Admin,Sales,Cashier")]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Cassandra.WebUi.Services
@inject MasterDataApiClient Api

<PageTitle>Cabang Leasing — Cassandra</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">Cabang Leasing</h4>
</div>

@if (_errors.Count > 0)
{
    <div class="alert alert-danger alert-dismissible">
        <ul class="mb-0 ps-3">
            @foreach (var e in _errors)
            {
                <li>@e</li>
            }
        </ul>
        <button type="button" class="btn-close" @onclick="() => _errors.Clear()"></button>
    </div>
}
@if (!string.IsNullOrEmpty(_notice))
{
    <div class="alert alert-success alert-dismissible">
        @_notice
        <button type="button" class="btn-close" @onclick="() => _notice = null"></button>
    </div>
}

<div class="row g-4">

    @* ── Left: Create / Edit form ── *@
    <div class="col-lg-4">
        @if (_editingId is null)
        {
            <div class="card">
                <div class="card-header fw-semibold">
                    <i class="bi bi-plus-circle me-1"></i> Tambah Cabang Leasing Baru
                </div>
                <div class="card-body">
                    <EditForm Model="_createForm" OnValidSubmit="HandleCreate">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label">Kode <span class="text-danger">*</span></label>
                            <InputText class="form-control text-uppercase" @bind-Value="_createForm.Code"
                                       @oninput="e => _createForm.Code = e.Value?.ToString()?.ToUpperInvariant() ?? string.Empty"
                                       placeholder="cth. ACC-JKT" />
                            <ValidationMessage For="() => _createForm.Code" class="small text-danger" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nama <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="_createForm.Name" placeholder="cth. ACC Jakarta Pusat" />
                            <ValidationMessage For="() => _createForm.Name" class="small text-danger" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Global Leasing <span class="text-danger">*</span></label>
                            <InputSelect class="form-select" @bind-Value="_createForm.GlobalLeasingId">
                                <option value="">— Pilih —</option>
                                @foreach (var g in _globalLeasingList.Where(g => g.IsActive))
                                {
                                    <option value="@g.Id">@g.Code — @g.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => _createForm.GlobalLeasingId" class="small text-danger" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Telepon</label>
                            <InputText class="form-control" @bind-Value="_createForm.Phone" placeholder="Opsional" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Fax</label>
                            <InputText class="form-control" @bind-Value="_createForm.Fax" placeholder="Opsional" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Contact</label>
                            <InputText class="form-control" @bind-Value="_createForm.Contact" placeholder="Opsional" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100" disabled="@_saving">
                            @if (_saving)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            else
                            {
                                <i class="bi bi-check-lg me-1"></i>
                            }
                            Simpan Cabang Leasing
                        </button>
                    </EditForm>
                </div>
            </div>
        }
        else
        {
            <div class="card border-warning">
                <div class="card-header fw-semibold text-warning-emphasis bg-warning-subtle d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-pencil me-1"></i> Ubah Cabang Leasing</span>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CancelEdit">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="card-body">
                    <EditForm Model="_editForm" OnValidSubmit="HandleUpdate">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label">Kode</label>
                            <p class="form-control-plaintext fw-semibold">@_editForm.Code</p>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nama <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="_editForm.Name" />
                            <ValidationMessage For="() => _editForm.Name" class="small text-danger" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Global Leasing <span class="text-danger">*</span></label>
                            <InputSelect class="form-select" @bind-Value="_editForm.GlobalLeasingId">
                                <option value="">— Pilih —</option>
                                @foreach (var g in _globalLeasingList.Where(g => g.IsActive))
                                {
                                    <option value="@g.Id">@g.Code — @g.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => _editForm.GlobalLeasingId" class="small text-danger" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Telepon</label>
                            <InputText class="form-control" @bind-Value="_editForm.Phone" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Fax</label>
                            <InputText class="form-control" @bind-Value="_editForm.Fax" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Contact</label>
                            <InputText class="form-control" @bind-Value="_editForm.Contact" />
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning flex-grow-1" disabled="@_saving">
                                @if (_saving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <i class="bi bi-check-lg me-1"></i>
                                }
                                Simpan
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit">Batal</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }
    </div>

    @* ── Right: list ── *@
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header fw-semibold">Semua Cabang Leasing</div>
            <div class="card-body p-0">
                @if (_list is null)
                {
                    <div class="p-3 text-muted">
                        <span class="spinner-border spinner-border-sm me-1"></span> Memuat…
                    </div>
                }
                else if (_list.Count == 0)
                {
                    <div class="p-3 text-muted">Belum ada cabang leasing yang terdaftar.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Kode</th>
                                    <th>Nama</th>
                                    <th>Global Leasing</th>
                                    <th>Telepon</th>
                                    <th>Status</th>
                                    <th class="text-end">Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _list)
                                {
                                    <tr class="@(_editingId == item.Id ? "table-warning" : "")">
                                        <td class="fw-semibold">@item.Code</td>
                                        <td>@item.Name</td>
                                        <td class="small">@GlobalLeasingName(item.GlobalLeasingId)</td>
                                        <td class="small">@(item.Phone ?? "—")</td>
                                        <td>
                                            @if (item.IsActive)
                                            {
                                                <span class="badge bg-success">Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Tidak Aktif</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <AuthorizeView Roles="Admin">
                                                <div class="d-flex gap-1 justify-content-end">
                                                    <button class="btn btn-sm @(_editingId == item.Id ? "btn-warning" : "btn-outline-secondary")"
                                                            title="Ubah" @onclick="() => StartEdit(item)">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    @if (item.IsActive)
                                                    {
                                                        <button class="btn btn-sm btn-outline-danger"
                                                                title="Nonaktifkan"
                                                                @onclick="() => HandleToggleStatus(item)">
                                                            <i class="bi bi-toggle-on"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-outline-success"
                                                                title="Aktifkan"
                                                                @onclick="() => HandleToggleStatus(item)">
                                                            <i class="bi bi-toggle-off"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </AuthorizeView>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

@code {
    private List<CabangLeasingDto>?  _list;
    private List<GlobalLeasingDto>   _globalLeasingList = [];
    private Guid?   _editingId;
    private string? _notice;
    private bool    _saving;

    private readonly List<string> _errors = [];

    private CabangLeasingCreateForm _createForm = new();
    private CabangLeasingEditForm   _editForm   = new();

    protected override async Task OnInitializedAsync()
    {
        var cabangTask = Api.GetCabangLeasingAsync();
        var globalTask = Api.GetGlobalLeasingAsync();
        await Task.WhenAll(cabangTask, globalTask);
        _list              = cabangTask.Result ?? [];
        _globalLeasingList = globalTask.Result ?? [];
    }

    private async Task LoadAsync()
        => _list = await Api.GetCabangLeasingAsync() ?? [];

    private string GlobalLeasingName(Guid id)
    {
        var g = _globalLeasingList.FirstOrDefault(x => x.Id == id);
        return g is null ? "—" : $"{g.Code} — {g.Name}";
    }

    private async Task HandleCreate()
    {
        _errors.Clear();
        _saving = true;

        var (id, errors) = await Api.CreateCabangLeasingAsync(
            _createForm.Code.Trim(),
            _createForm.Name.Trim(),
            string.IsNullOrWhiteSpace(_createForm.Phone)   ? null : _createForm.Phone.Trim(),
            string.IsNullOrWhiteSpace(_createForm.Fax)     ? null : _createForm.Fax.Trim(),
            string.IsNullOrWhiteSpace(_createForm.Contact) ? null : _createForm.Contact.Trim(),
            _createForm.GlobalLeasingId);

        _saving = false;

        if (errors is not null) { _errors.AddRange(errors); return; }

        _notice     = $"Cabang Leasing '{_createForm.Name}' berhasil ditambahkan.";
        _createForm = new();
        await LoadAsync();
    }

    private async Task HandleUpdate()
    {
        if (_editingId is null) return;

        _errors.Clear();
        _saving = true;

        var errors = await Api.UpdateCabangLeasingAsync(
            _editingId.Value,
            _editForm.Name.Trim(),
            string.IsNullOrWhiteSpace(_editForm.Phone)   ? null : _editForm.Phone.Trim(),
            string.IsNullOrWhiteSpace(_editForm.Fax)     ? null : _editForm.Fax.Trim(),
            string.IsNullOrWhiteSpace(_editForm.Contact) ? null : _editForm.Contact.Trim(),
            _editForm.GlobalLeasingId);

        _saving = false;

        if (errors is not null) { _errors.AddRange(errors); return; }

        _notice    = "Cabang Leasing berhasil diperbarui.";
        _editingId = null;
        _editForm  = new();
        await LoadAsync();
    }

    private async Task HandleToggleStatus(CabangLeasingDto item)
    {
        _errors.Clear();

        var errors = await Api.SetCabangLeasingStatusAsync(item.Id, !item.IsActive);

        if (errors is not null) { _errors.AddRange(errors); return; }

        _notice = $"Cabang Leasing '{item.Name}' berhasil {(item.IsActive ? "dinonaktifkan" : "diaktifkan")}.";
        await LoadAsync();
    }

    private void StartEdit(CabangLeasingDto item)
    {
        _editingId              = item.Id;
        _editForm.Code          = item.Code;
        _editForm.Name          = item.Name;
        _editForm.GlobalLeasingId = item.GlobalLeasingId;
        _editForm.Phone         = item.Phone;
        _editForm.Fax           = item.Fax;
        _editForm.Contact       = item.Contact;
        _errors.Clear();
        _notice = null;
    }

    private void CancelEdit()
    {
        _editingId = null;
        _editForm  = new();
        _errors.Clear();
    }

    // ── Form models ────────────────────────────────────────────────────────────

    private sealed class CabangLeasingCreateForm
    {
        [Required(ErrorMessage = "Kode wajib diisi.")]
        [MaxLength(20, ErrorMessage = "Kode maksimal 20 karakter.")]
        public string Code { get; set; } = string.Empty;

        [Required(ErrorMessage = "Nama wajib diisi.")]
        [MaxLength(200, ErrorMessage = "Nama maksimal 200 karakter.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Global Leasing wajib dipilih.")]
        public Guid GlobalLeasingId { get; set; }

        [MaxLength(30)]
        public string? Phone { get; set; }

        [MaxLength(30)]
        public string? Fax { get; set; }

        [MaxLength(100)]
        public string? Contact { get; set; }
    }

    private sealed class CabangLeasingEditForm
    {
        public string Code { get; set; } = string.Empty;

        [Required(ErrorMessage = "Nama wajib diisi.")]
        [MaxLength(200, ErrorMessage = "Nama maksimal 200 karakter.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Global Leasing wajib dipilih.")]
        public Guid GlobalLeasingId { get; set; }

        [MaxLength(30)]
        public string? Phone { get; set; }

        [MaxLength(30)]
        public string? Fax { get; set; }

        [MaxLength(100)]
        public string? Contact { get; set; }
    }
}
