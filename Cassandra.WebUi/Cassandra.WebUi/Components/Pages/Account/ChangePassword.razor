@page "/account/change-password"
@attribute [Authorize]
@rendermode InteractiveServer
@using Cassandra.WebUi.Services
@inject AccountApiClient Account

<PageTitle>Ubah Kata Sandi — Cassandra</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">Ubah Kata Sandi</h4>
</div>

@if (_errors.Count > 0)
{
    <div class="alert alert-danger alert-dismissible" style="max-width:680px">
        <ul class="mb-0 ps-3">
            @foreach (var e in _errors) { <li>@e</li> }
        </ul>
        <button type="button" class="btn-close" @onclick="() => _errors.Clear()"></button>
    </div>
}
@if (!string.IsNullOrEmpty(_notice))
{
    <div class="alert alert-success alert-dismissible" style="max-width:680px">
        @_notice
        <button type="button" class="btn-close" @onclick="() => _notice = null"></button>
    </div>
}

<div class="card" style="max-width:680px">
    <div class="card-header fw-semibold">
        <i class="bi bi-shield-lock me-1"></i> Keamanan Akun
    </div>
    <div class="card-body">
        <EditForm Model="this" OnValidSubmit="HandleSubmit">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label">Kata Sandi Saat Ini <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="_current" type="password"
                               autocomplete="current-password" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Kata Sandi Baru <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="_new" type="password"
                               autocomplete="new-password"
                               placeholder="Min. 8 karakter, 1 angka, 1 huruf kapital" />
                    <div class="form-text">Min. 8 karakter, setidaknya 1 angka dan 1 huruf kapital.</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Ulangi Kata Sandi Baru <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="_confirm" type="password"
                               autocomplete="new-password" />
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@_busy">
                    @if (_busy)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    else
                    {
                        <i class="bi bi-check-lg me-1"></i>
                    }
                    Simpan
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private string _current = string.Empty;
    private string _new = string.Empty;
    private string _confirm = string.Empty;
    private bool _busy;
    private string? _notice;
    private readonly List<string> _errors = [];

    private async Task HandleSubmit()
    {
        _errors.Clear();
        _notice = null;

        foreach (var e in ValidatePassword(_new))
            _errors.Add(e);
        if (_new == _current && !string.IsNullOrEmpty(_new))
            _errors.Add("Kata sandi baru harus berbeda dari kata sandi saat ini.");
        if (_new != _confirm)
            _errors.Add("Konfirmasi kata sandi tidak cocok.");
        if (string.IsNullOrEmpty(_current))
            _errors.Add("Kata sandi saat ini wajib diisi.");
        if (_errors.Count > 0)
            return;

        _busy = true;
        var result = await Account.ChangePasswordAsync(_current, _new);
        _busy = false;

        if (result.Ok)
        {
            _notice = result.Message ?? "Kata sandi berhasil diubah.";
            _current = _new = _confirm = string.Empty;
        }
        else
        {
            _errors.AddRange(result.Errors);
        }
    }

    private static List<string> ValidatePassword(string? pwd)
    {
        var errs = new List<string>();
        if (string.IsNullOrEmpty(pwd) || pwd.Length < 8)
            errs.Add("Kata sandi minimal 8 karakter.");
        if (pwd is not null && !pwd.Any(char.IsDigit))
            errs.Add("Kata sandi harus mengandung setidaknya 1 angka.");
        if (pwd is not null && !pwd.Any(char.IsUpper))
            errs.Add("Kata sandi harus mengandung setidaknya 1 huruf kapital.");
        return errs;
    }
}
