@page "/forgot-password"
@layout LoginLayout
@rendermode InteractiveServer
@using Cassandra.WebUi.Services
@inject AuthService Auth

<PageTitle>Lupa Kata Sandi — ModeOn</PageTitle>

<div class="d-flex align-items-center justify-content-center min-vh-100 bg-light">
    <div class="card shadow-sm" style="width: 100%; max-width: 420px;">
        <div class="card-body p-4">
            <h4 class="card-title mb-1 fw-bold">Lupa Kata Sandi</h4>
            <p class="text-muted mb-4 small">
                Masukkan email akun Anda. Kami akan mengirim tautan untuk mengatur ulang kata sandi.
            </p>

            @if (_sent)
            {
                <div class="alert alert-success py-2 small" role="alert">
                    @_message
                </div>
                <a href="/login" class="btn btn-outline-secondary w-100">Kembali ke Masuk</a>
            }
            else
            {
                @if (_errors.Count > 0)
                {
                    <div class="alert alert-danger py-2 small" role="alert">
                        <ul class="mb-0 ps-3">
                            @foreach (var e in _errors) { <li>@e</li> }
                        </ul>
                    </div>
                }

                <EditForm Model="this" OnValidSubmit="HandleSubmit">
                    <div class="mb-3">
                        <label class="form-label" for="email">Email</label>
                        <InputText id="email" @bind-Value="_email" type="email"
                                   class="form-control" autocomplete="email"
                                   placeholder="masukan email" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100" disabled="@_busy">
                        @if (_busy)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Kirim Tautan
                    </button>
                </EditForm>

                <div class="text-center mt-3">
                    <a href="/login" class="small">Kembali ke Masuk</a>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string _email = string.Empty;
    private bool _busy;
    private bool _sent;
    private string? _message;
    private readonly List<string> _errors = [];

    private async Task HandleSubmit()
    {
        _errors.Clear();
        if (string.IsNullOrWhiteSpace(_email))
        {
            _errors.Add("Email wajib diisi.");
            return;
        }

        _busy = true;
        var result = await Auth.ForgotPasswordAsync(_email.Trim());
        _busy = false;

        if (result.Ok)
        {
            _message = result.Message ?? "Jika email terdaftar, tautan atur ulang kata sandi telah dikirim.";
            _sent = true;
        }
        else
        {
            _errors.AddRange(result.Errors);
        }
    }
}
