@page "/forgot-password"
@layout LoginLayout
@rendermode InteractiveServer
@using Cassandra.WebUi.Services
@inject AuthService Auth

<PageTitle>Lupa Kata Sandi — ModeOn</PageTitle>

<AuthCard Title="Lupa Kata Sandi"
          Subtitle="Masukkan email akun Anda. Kami akan mengirim tautan untuk mengatur ulang kata sandi.">
    @if (_sent)
    {
        <div class="alert alert-success py-2 small d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-check-circle flex-shrink-0"></i>
            <span>@_message</span>
        </div>
        <a href="/login" class="btn btn-outline-secondary w-100">
            <i class="bi bi-arrow-left me-1"></i> Kembali ke Masuk
        </a>
    }
    else
    {
        @if (_errors.Count > 0)
        {
            <div class="alert alert-danger py-2 small" role="alert">
                <ul class="mb-0 ps-3">
                    @foreach (var e in _errors) { <li>@e</li> }
                </ul>
            </div>
        }

        <EditForm Model="this" OnValidSubmit="HandleSubmit">
            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                    <InputText id="email" @bind-Value="_email" type="email"
                               class="form-control" autocomplete="email"
                               placeholder="nama@dealer.com" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100" disabled="@_busy">
                @if (_busy)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                else
                {
                    <i class="bi bi-send me-1"></i>
                }
                Kirim Tautan
            </button>
        </EditForm>

        <div class="text-center mt-3">
            <a href="/login" class="small">Kembali ke Masuk</a>
        </div>
    }
</AuthCard>

@code {
    private string _email = string.Empty;
    private bool _busy;
    private bool _sent;
    private string? _message;
    private readonly List<string> _errors = [];

    private async Task HandleSubmit()
    {
        _errors.Clear();
        if (string.IsNullOrWhiteSpace(_email))
        {
            _errors.Add("Email wajib diisi.");
            return;
        }

        _busy = true;
        var result = await Auth.ForgotPasswordAsync(_email.Trim());
        _busy = false;

        if (result.Ok)
        {
            _message = result.Message ?? "Jika email terdaftar, tautan atur ulang kata sandi telah dikirim.";
            _sent = true;
        }
        else
        {
            _errors.AddRange(result.Errors);
        }
    }
}
