@using Microsoft.AspNetCore.Components.Authorization

<MudNavMenu Class="pt-2">

    <MudNavLink Href="" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Home">
        Beranda
    </MudNavLink>

    @* ── Platform administration (SuperAdmin only) ── *@
    <AuthorizeView Roles="SuperAdmin">

        @if (_drawerOpen)
        {
            <MudText Typo="Typo.overline" Class="px-4 pt-3 pb-0 d-block"
                     Style="font-size:.6rem;letter-spacing:.1em;
                            color:var(--mud-palette-drawer-text);opacity:.5">
                Platform
            </MudText>
        }
        else
        {
            <MudDivider Class="my-2 mx-2" />
        }

        <MudNavLink Href="platform/dealers" Icon="@Icons.Material.Filled.Storefront">
            Dealer
        </MudNavLink>

        <MudNavLink Href="platform/users" Icon="@Icons.Material.Filled.ManageAccounts">
            Pengguna
        </MudNavLink>

    </AuthorizeView>

    @* ── Dealer staff management (dealer Admin only) ── *@
    <AuthorizeView Roles="Admin">

        @if (_drawerOpen)
        {
            <MudText Typo="Typo.overline" Class="px-4 pt-3 pb-0 d-block"
                     Style="font-size:.6rem;letter-spacing:.1em;
                            color:var(--mud-palette-drawer-text);opacity:.5">
                Administrasi
            </MudText>
        }
        else
        {
            <MudDivider Class="my-2 mx-2" />
        }

        <MudNavLink Href="dealer/users" Icon="@Icons.Material.Filled.Group">
            Staf
        </MudNavLink>

    </AuthorizeView>

    @* ── Master Data (Admin, Sales, Cashier) ── *@
    <AuthorizeView Roles="Admin,Sales,Cashier">

        @if (_drawerOpen)
        {
            <MudText Typo="Typo.overline" Class="px-4 pt-3 pb-0 d-block"
                     Style="font-size:.6rem;letter-spacing:.1em;
                            color:var(--mud-palette-drawer-text);opacity:.5">
                Master Data
            </MudText>
        }
        else
        {
            <MudDivider Class="my-2 mx-2" />
        }

        <MudNavGroup Title="Master Data" Icon="@Icons.Material.Filled.Folder" Expanded="false">
            <MudNavLink Href="dealer/jabatan" Icon="@Icons.Material.Filled.Badge">
                Jabatan
            </MudNavLink>
            <MudNavLink Href="dealer/karyawan" Icon="@Icons.Material.Filled.People">
                Karyawan
            </MudNavLink>
            <MudNavLink Href="dealer/kios" Icon="@Icons.Material.Filled.Store">
                Kios
            </MudNavLink>
            <MudNavLink Href="dealer/mediator" Icon="@Icons.Material.Filled.RecordVoiceOver">
                Mediator
            </MudNavLink>
            <MudNavLink Href="dealer/warna" Icon="@Icons.Material.Filled.Palette">
                Warna
            </MudNavLink>
            <MudNavLink Href="dealer/grup-tipe-motor" Icon="@Icons.Material.Filled.Category">
                Grup Tipe Motor
            </MudNavLink>
            <MudNavLink Href="dealer/tipe-motor" Icon="@Icons.Material.Filled.TwoWheeler">
                Tipe Motor
            </MudNavLink>
            <MudNavLink Href="dealer/kelengkapan" Icon="@Icons.Material.Filled.Extension">
                Kelengkapan
            </MudNavLink>
        </MudNavGroup>

        <MudNavGroup Title="Keuangan &amp; Leasing" Icon="@Icons.Material.Filled.AccountBalance" Expanded="false">
            <MudNavLink Href="dealer/metode-keuangan" Icon="@Icons.Material.Filled.Payment">
                Metode Keuangan
            </MudNavLink>
            <MudNavLink Href="dealer/global-leasing" Icon="@Icons.Material.Filled.AccountBalance">
                Global Leasing
            </MudNavLink>
            <MudNavLink Href="dealer/cabang-leasing" Icon="@Icons.Material.Filled.LocationCity">
                Cabang Leasing
            </MudNavLink>
            <MudNavLink Href="dealer/grup-tenor" Icon="@Icons.Material.Filled.Schedule">
                Grup Tenor
            </MudNavLink>
            <MudNavLink Href="dealer/tenor" Icon="@Icons.Material.Filled.Timer">
                Tenor
            </MudNavLink>
            <MudNavLink Href="dealer/daftar-harga-leasing" Icon="@Icons.Material.Filled.PriceChange">
                Daftar Harga Leasing
            </MudNavLink>
            <MudNavLink Href="dealer/discount" Icon="@Icons.Material.Filled.Discount">
                Diskon Kredit
            </MudNavLink>
            <MudNavLink Href="dealer/discount-cash" Icon="@Icons.Material.Filled.LocalOffer">
                Diskon Cash
            </MudNavLink>
            <MudNavLink Href="dealer/alokasi-diskon" Icon="@Icons.Material.Filled.PersonPin">
                Alokasi Diskon
            </MudNavLink>
            <MudNavLink Href="dealer/df" Icon="@Icons.Material.Filled.Percent">
                DF (Biaya Pembiayaan)
            </MudNavLink>
        </MudNavGroup>

        <MudNavGroup Title="Biro &amp; Samsat" Icon="@Icons.Material.Filled.AccountTree" Expanded="false">
            <MudNavLink Href="dealer/samsat" Icon="@Icons.Material.Filled.LocationOn">
                Samsat
            </MudNavLink>
            <MudNavLink Href="dealer/biro" Icon="@Icons.Material.Filled.Business">
                Biro
            </MudNavLink>
            <MudNavLink Href="dealer/biaya-biro-jasa" Icon="@Icons.Material.Filled.RequestQuote">
                Biaya Biro Jasa
            </MudNavLink>
            <MudNavLink Href="dealer/expense-type" Icon="@Icons.Material.Filled.MoneyOff">
                Jenis Pengeluaran
            </MudNavLink>
            <MudNavLink Href="dealer/ledger" Icon="@Icons.Material.Filled.MenuBook">
                Ledger
            </MudNavLink>
            <MudNavLink Href="dealer/pelanggaran-wilayah" Icon="@Icons.Material.Filled.GpsOff">
                Pelanggaran Wilayah
            </MudNavLink>
        </MudNavGroup>

    </AuthorizeView>

</MudNavMenu>

@code {
    [CascadingParameter(Name = "DrawerOpen")]
    private bool _drawerOpen { get; set; }
}
