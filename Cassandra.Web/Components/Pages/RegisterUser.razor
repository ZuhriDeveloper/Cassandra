@page "/register/user"
@layout Layout.EmptyLayout
@inject RegistrationService RegistrationService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Register User – Cassandra</PageTitle>

<div class="reg-wrapper">
    <div class="reg-card">

        <div class="reg-header">
            <div class="reg-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.029 10 8 10c-2.029 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
                </svg>
            </div>
            <h1 class="reg-title">Register User</h1>
            <p class="reg-subtitle">Create a new user account</p>
        </div>

        @if (_success)
        {
            <div class="alert-success" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                </svg>
                User account created successfully!
                <button class="btn-link-inline" @onclick="Reset">Create another</button>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert-error" role="alert">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                        <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/>
                    </svg>
                    @_errorMessage
                </div>
            }

            <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="register-user">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label">Username <span class="required">*</span></label>
                    <InputText class="form-control" @bind-Value="_model.Username"
                               placeholder="e.g. john.doe" autocomplete="username" disabled="@_isLoading" />
                    <ValidationMessage For="() => _model.Username" class="field-error" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Password <span class="required">*</span></label>
                    <div class="input-group">
                        <InputText type="@(_showPassword ? "text" : "password")"
                                   class="form-control"
                                   @bind-Value="_model.Password"
                                   placeholder="Min. 6 characters"
                                   autocomplete="new-password"
                                   disabled="@_isLoading" />
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => _showPassword = !_showPassword" tabindex="-1">
                            @if (_showPassword)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486l.708.709z"/><path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z"/><path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12-.708.708z"/>
                                </svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                                </svg>
                            }
                        </button>
                    </div>
                    <ValidationMessage For="() => _model.Password" class="field-error" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Confirm Password <span class="required">*</span></label>
                    <InputText type="@(_showPassword ? "text" : "password")"
                               class="form-control"
                               @bind-Value="_model.ConfirmPassword"
                               placeholder="Re-enter your password"
                               autocomplete="new-password"
                               disabled="@_isLoading" />
                    <ValidationMessage For="() => _model.ConfirmPassword" class="field-error" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Role <span class="required">*</span></label>
                    <InputSelect class="form-select" @bind-Value="_model.RoleId" disabled="@(_isLoading || _roles.Count == 0)">
                        <option value="0">— Select a role —</option>
                        @foreach (var role in _roles)
                        {
                            <option value="@role.Id">@role.Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => _model.RoleId" class="field-error" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Link to Employee <span class="optional">(optional)</span></label>
                    <InputSelect class="form-select" @bind-Value="_model.EmployeeId" disabled="@(_isLoading || _employees.Count == 0)">
                        <option value="">— None —</option>
                        @foreach (var emp in _employees)
                        {
                            <option value="@emp.Id">@emp.FullName (@emp.Email)</option>
                        }
                    </InputSelect>
                    <div class="field-hint">Optionally link this account to an existing employee record.</div>
                </div>

                <button type="submit" class="btn-submit w-100" disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Creating account…</span>
                    }
                    else
                    {
                        <span>Create User Account</span>
                    }
                </button>
            </EditForm>
        }

        <p class="reg-footer">
            <a href="/login">← Back to Login</a>
            &nbsp;·&nbsp;
            <a href="/register/employee">Register Employee instead</a>
        </p>
    </div>
</div>

@code {
    private UserFormModel _model = new();
    private string? _errorMessage;
    private bool _isLoading;
    private bool _success;
    private bool _showPassword;
    private List<RoleDto> _roles = [];
    private List<EmployeeDto> _employees = [];

    protected override async Task OnInitializedAsync()
    {
        _roles     = await RegistrationService.GetRolesAsync();
        _employees = await RegistrationService.GetEmployeesAsync();
    }

    private async Task HandleSubmit()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var (success, error) = await RegistrationService.RegisterUserAsync(
                new RegisterUserRequest(
                    _model.Username,
                    _model.Password,
                    _model.RoleId,
                    _model.EmployeeId == 0 ? null : _model.EmployeeId));

            if (success)
                _success = true;
            else
                _errorMessage = error;
        }
        catch
        {
            _errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Reset()
    {
        _model = new();
        _success = false;
        _errorMessage = null;
    }

    private sealed class UserFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Username is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(50, MinimumLength = 3, ErrorMessage = "Username must be 3–50 characters.")]
        [System.ComponentModel.DataAnnotations.RegularExpression(@"^[a-zA-Z0-9._-]+$", ErrorMessage = "Only letters, numbers, dots, hyphens and underscores allowed.")]
        public string Username { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters.")]
        public string Password { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please confirm your password.")]
        [System.ComponentModel.DataAnnotations.Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Range(1, int.MaxValue, ErrorMessage = "Please select a role.")]
        public int RoleId { get; set; }

        public int? EmployeeId { get; set; }
    }
}
